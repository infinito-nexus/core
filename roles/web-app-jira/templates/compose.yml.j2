{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}
  jira:
    {{ lookup('template', 'roles/sys-svc-container/templates/build.yml.j2') | indent(4) }}
      args:
        JIRA_IMAGE: "{{ JIRA_IMAGE }}"
        JIRA_VERSION: "{{ JIRA_VERSION }}"
        JIRA_STORAGE_PATH: "{{ JIRA_STORAGE_PATH }}"
    {{ lookup('container_image', application_id, 'jira', custom=True) }}
    {{ lookup('compose_only', 'container_name', JIRA_CONTAINER) }}
    hostname: '{{ JIRA_HOSTNAME }}'
    ports:
      - "{{ DOCKER_BIND_HOST }}:{{ lookup('config', application_id, 'services.jira.ports.local.http') }}:{{ lookup('config', application_id, 'services.jira.ports.internal.http') }}"
{{ lookup('container_volumes', application_id, 'jira') | indent(4) }}
{% include 'roles/sys-svc-container/templates/healthcheck/curl.yml.j2' %}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
{{ lookup('container_depends_on', application_id) }}
    {{ lookup('container_networks') | indent(4) }}

{{ lookup('compose_volumes', application_id) }}
{{ lookup('compose_networks') }}
