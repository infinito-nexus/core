{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

  {% set service_name = LIBRETRANSLATE_SERVICE %}
  {{ service_name }}:
    {{ lookup('template', 'roles/sys-svc-container/templates/build.yml.j2') | indent(4) }}
      args:
        LIBRETRANSLATE_IMAGE: "{{ LIBRETRANSLATE_IMAGE }}"
        LIBRETRANSLATE_VERSION: "{{ LIBRETRANSLATE_VERSION }}"
        LIBRETRANSLATE_LOAD_ONLY: "{{ LIBRETRANSLATE_LOAD_ONLY }}"
    {{ lookup('container_image', application_id, 'libretranslate') }}
    volumes: []
    {{ lookup('container_ports', ['libretranslate', 'http', DOCKER_BIND_HOST]) | indent(4) }}
    healthcheck:
      test: ["CMD-SHELL", "./venv/bin/python scripts/healthcheck.py"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_networks') | indent(4) }}

{{ lookup('compose_volumes', application_id,
) }}

{{ lookup('compose_networks') }}
