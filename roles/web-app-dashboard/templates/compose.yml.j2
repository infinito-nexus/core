{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}
{% set service_name = 'dashboard' %}
  {{ service_name }}:
{% include 'roles/sys-svc-container/templates/deploy.yml.j2' %}
{% set container_port = 5000 %}
    image: {{ DASHBOARD_IMAGE }}:{{ DASHBOARD_VERSION }}
    {{ lookup('compose_only', 'container_name', DASHBOARD_CONTAINER) }}
    ports:
      - {{ DOCKER_BIND_HOST }}:{{ http_port }}:{{ container_port }}
    volumes:
      - "{{ DASHBOARD_CONFIG_YML_DEST }}:{{ DASHBOARD_CONFIG_YML_DOCKER_DEST }}:ro"
    {{ lookup('compose_restart') }}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
{% include 'roles/sys-svc-container/templates/healthcheck/tcp.yml.j2' %}

{{ lookup('compose_volumes', application_id) }}

