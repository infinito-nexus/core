{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

{% set service_name = ODOO_SERVICE %}
  {{ service_name }}:
    {{ lookup('template', 'roles/sys-svc-container/templates/build.yml.j2') | indent(4) }}
      args:
        ODOO_IMAGE: "{{ ODOO_IMAGE }}"
        ODOO_VERSION: "{{ ODOO_VERSION }}"
    {{ lookup('compose_only', 'container_name', ODOO_CONTAINER) }}
    image: "{{ ODOO_CUSTOM_IMAGE }}"
    init: true
    stop_signal: SIGTERM
    stop_grace_period: 30s
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
{% set container_port = 8069 %}
{% set container_healthcheck = 'web/health' %}
{% include 'roles/sys-svc-container/templates/healthcheck/curl.yml.j2' %}
    ports:
      - "{{ DOCKER_BIND_HOST }}:{{ lookup('config', application_id, 'services.odoo.ports.local.http') }}:{{ container_port }}"
      - "{{ DOCKER_BIND_HOST }}:{{ lookup('config', application_id, 'services.odoo.ports.local.websocket') }}:{{ container_websocket_port }}"
    environment:
      - HOST={{ ODOO_DB_HOST }}
      - USER={{ ODOO_DB_USER }}
      - PASSWORD={{ ODOO_DB_PASSWORD }}
      - ODOO_URL={{ ODOO_URL }}
{% if ODOO_OIDC_ENABLED | bool %}
      - ODOO_OIDC_CLIENT_ID={{ ODOO_OIDC_CLIENT_ID }}
      - ODOO_OIDC_CLIENT_SECRET={{ ODOO_OIDC_CLIENT_SECRET }}
      - ODOO_OIDC_ISSUER_URL={{ ODOO_OIDC_ISSUER_URL }}
      - ODOO_OIDC_TOKEN_URL={{ ODOO_OIDC_TOKEN_URL }}
      - ODOO_OIDC_JWKS_URI={{ ODOO_OIDC_JWKS_URI }}
      - ODOO_OIDC_UID_FIELD={{ ODOO_OIDC_UID_FIELD }}
{% endif %}
{{ lookup('container_depends_on', application_id) }}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
    {{ lookup('container_volumes', application_id, service_name,
        extra_volumes=[ODOO_ADDONS_HOST ~ ':/mnt/custom-addons:ro']) | indent(4) }}

{{ lookup('compose_volumes', application_id) }}
{% include 'roles/sys-svc-compose/templates/networks.yml.j2' %}
