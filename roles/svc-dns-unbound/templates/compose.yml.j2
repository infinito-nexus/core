{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

  {% set service_name = 'unbound' %}
  {{ service_name }}:
    {{ lookup('compose_only', 'container_name', UNBOUND_CONTAINER) }}
    {{ lookup('container_image', application_id, 'unbound') }}
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {% if DEPLOYMENT_MODE == 'compose' and not (DOCKER_IN_CONTAINER | bool) %}
    ports:
      - "{{ DOCKER_BIND_HOST }}:{{ UNBOUND_PORT }}:53/udp"  # nocheck: compose-ports-must-use-container-ports
      - "{{ DOCKER_BIND_HOST }}:{{ UNBOUND_PORT }}:53/tcp"  # nocheck: compose-ports-must-use-container-ports
    {% endif %}
    {{ lookup('container_volumes', application_id, 'unbound') | indent(4) }}
    networks:  # nocheck: networks-literal  static-IP resolver on its own engine overlay so consumers can point dns: at it
      {{ UNBOUND_NETWORK_NAME }}:
        ipv4_address: {{ UNBOUND_RESOLVER_IP }}

{{ lookup('compose_volumes', application_id) }}
{{ lookup('compose_networks') }}
