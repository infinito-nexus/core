{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

  {% set service_name = JITSI_PROSODY_SERVICE %}
  {{ service_name }}:
    {{ lookup('container_image', application_id, JITSI_PROSODY_SERVICE) }}
    {{ lookup('compose_only', 'container_name', JITSI_PROSODY_CONTAINER) }}
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    expose:
      - "{{ JITSI_PROSODY_XMPP_PORT }}"
      - "{{ JITSI_PROSODY_COMPONENT_PORT }}"
      - "{{ JITSI_PROSODY_HTTP_PORT }}"
    {{ lookup('container_volumes', application_id, JITSI_PROSODY_SERVICE) | indent(4) }}
    {{ lookup('container_networks') | indent(4) }}

  {% set service_name = JITSI_JICOFO_SERVICE %}
  {{ service_name }}:
    {{ lookup('container_image', application_id, JITSI_JICOFO_SERVICE) }}
    {{ lookup('compose_only', 'container_name', JITSI_JICOFO_CONTAINER) }}
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('depends_on', {JITSI_PROSODY_SERVICE: 'service_started'}) }}
    {{ lookup('container_volumes', application_id, JITSI_JICOFO_SERVICE) | indent(4) }}
    {{ lookup('container_networks') | indent(4) }}

  {% set service_name = JITSI_JVB_SERVICE %}
  {{ service_name }}:
    {{ lookup('container_image', application_id, JITSI_JVB_SERVICE) }}
    {{ lookup('compose_only', 'container_name', JITSI_JVB_CONTAINER) }}
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('depends_on', {JITSI_PROSODY_SERVICE: 'service_started'}) }}
    ports:
      - "{{ JITSI_JVB_MEDIA_PORT }}:{{ JITSI_JVB_MEDIA_PORT }}/udp"  # nocheck: compose-ports-must-use-container-ports
    {{ lookup('container_volumes', application_id, JITSI_JVB_SERVICE) | indent(4) }}
    {{ lookup('container_networks') | indent(4) }}

  {% set service_name = JITSI_WEB_SERVICE %}
  {{ service_name }}:
    {{ lookup('container_image', application_id, 'jitsi') }}
    {{ lookup('compose_only', 'container_name', JITSI_WEB_CONTAINER) }}
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('depends_on', {JITSI_PROSODY_SERVICE: 'service_started'}) }}
    {{ lookup('container_ports', ['jitsi', 'http', DOCKER_BIND_HOST]) | indent(4) }}
    {{ lookup('container_volumes', application_id, JITSI_WEB_SERVICE) | indent(4) }}
    {{ lookup('container_networks') | indent(4) }}

{{ lookup('compose_volumes', application_id,
    extra_volumes={}
) }}
{{ lookup('compose_networks') }}
