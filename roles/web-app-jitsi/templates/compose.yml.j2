{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

  {{ JITSI_PROSODY_CONTAINER }}:
    image: "{{ JITSI_PROSODY_IMAGE }}:{{ JITSI_PROSODY_VERSION }}"
    {{ lookup('compose_only', 'container_name', JITSI_PROSODY_CONTAINER) }}
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    expose:
      - "5222"
      - "5347"
      - "5280"
    {{ lookup('container_volumes', application_id, JITSI_PROSODY_CONTAINER) | indent(4) }}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}

  {{ JITSI_JICOFO_CONTAINER }}:
    image: "{{ JITSI_JICOFO_IMAGE }}:{{ JITSI_JICOFO_VERSION }}"
    {{ lookup('compose_only', 'container_name', JITSI_JICOFO_CONTAINER) }}
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('depends_on', {JITSI_PROSODY_CONTAINER: 'service_started'}) }}
    {{ lookup('container_volumes', application_id, JITSI_JICOFO_CONTAINER) | indent(4) }}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}

  {{ JITSI_JVB_CONTAINER }}:
    image: "{{ JITSI_JVB_IMAGE }}:{{ JITSI_JVB_VERSION }}"
    {{ lookup('compose_only', 'container_name', JITSI_JVB_CONTAINER) }}
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('depends_on', {JITSI_PROSODY_CONTAINER: 'service_started'}) }}
    ports:
      - "{{ JITSI_JVB_MEDIA_PORT }}:{{ JITSI_JVB_MEDIA_PORT }}/udp"
    {{ lookup('container_volumes', application_id, JITSI_JVB_CONTAINER) | indent(4) }}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}

  {{ JITSI_WEB_CONTAINER }}:
    image: "{{ JITSI_WEB_IMAGE }}:{{ JITSI_WEB_VERSION }}"
    {{ lookup('compose_only', 'container_name', JITSI_WEB_CONTAINER) }}
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('depends_on', {JITSI_PROSODY_CONTAINER: 'service_started'}) }}
    ports:
      - "{{ DOCKER_BIND_HOST }}:{{ JITSI_WEB_HTTP_PORT }}:80"
    {{ lookup('container_volumes', application_id, JITSI_WEB_CONTAINER) | indent(4) }}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}

{{ lookup('compose_volumes', application_id,
    extra_volumes={}
) }}
{% include 'roles/sys-svc-compose/templates/networks.yml.j2' %}
