{% include 'roles/sys-svc-container/templates/env.j2' %}

MOODLE_WWWROOT={{ lookup('tls', application_id, 'url.base') | regex_replace('/$', '') }}
MOODLE_DATAROOT={{ MOODLE_DATA_DIR }}

MOODLE_DB_TYPE=mariadb
MOODLE_DB_HOST={{ lookup('database', application_id, 'host') }}
MOODLE_DB_PORT={{ lookup('database', application_id, 'port') }}
MOODLE_DB_NAME={{ lookup('database', application_id, 'name') }}
MOODLE_DB_USER={{ lookup('database', application_id, 'username') }}
MOODLE_DB_PASS={{ lookup('database', application_id, 'password') | dotenv_quote }}
MOODLE_DB_PREFIX=mdl_

MOODLE_REVERSEPROXY=false
MOODLE_SSLPROXY=true

MOODLE_DEBUG={{ MODE_DEBUG | bool }}

MOODLE_SITE_NAME={{ MOODLE_SITE_TITLE | dotenv_quote }}
MOODLE_ADMIN_EMAIL={{ lookup('config', application_id, 'users.administrator.email') }}
