{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}
  {% set container_healthcheck_start_period = '20m' %}

  {% set service_name = NEXTCLOUD_PROXY_SERVICE %}
  {{ service_name }}:
    {% include 'roles/sys-svc-container/templates/deploy.yml.j2' %}
    {{ lookup('container_image', application_id, 'proxy') }}
    {{ lookup('compose_only', 'container_name', NEXTCLOUD_PROXY_CONTAINER) }}
    logging:
      driver: journald
    {{ lookup('compose_restart') }}
    {{ lookup('container_ports', ['nextcloud', 'http', DOCKER_BIND_HOST]) | indent(4) }}
    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
    {% include 'roles/sys-svc-container/templates/healthcheck/curl.yml.j2'  %}
    {{ lookup('container_networks') | indent(4) }}
    {% if NEXTCLOUD_HPB_NETWORK_MODE == 'host' %}
    extra_hosts:
      - "host.docker.internal:host-gateway"
    {% endif %}

  {% set service_name = NEXTCLOUD_SERVICE %}
  {{ service_name }}:
    {{ lookup('container_image', application_id, 'nextcloud') }}
    {{ lookup('compose_only', 'container_name', NEXTCLOUD_CONTAINER) }}
    {{ lookup('template', 'roles/sys-svc-container/templates/build.yml.j2') | indent(4) }}

    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
    {% if DEPLOYMENT_MODE == 'swarm' %}
    environment:
      TASK_SLOT: "{% raw %}{{.Task.Slot}}{% endraw %}"
    {% endif %}
    sysctls:
      net.ipv6.conf.all.disable_ipv6: "{{ (not NETWORK_IPV6_ENABLED | bool) | int }}"
    healthcheck:
      test: ["CMD", "su", "www-data", "-s", "/bin/sh", "-c", "php {{ NEXTCLOUD_INTERNAL_OCC_COMMAND }} status"]
      interval: 1m
      timeout: 30s
      retries: 10
      start_period: {{ container_healthcheck_start_period }}
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_depends_on', application_id) | indent(4) }}
    {{ lookup('container_networks') | indent(4) }}

  {% if NEXTCLOUD_HPB_SIGNALING_ENABLED | bool %}
  {% set service_name = NEXTCLOUD_HPB_SERVICE %}
  {% set container_port = NEXTCLOUD_HPB_SIGNALING_PORT %}
  {{ service_name }}:
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {% include 'roles/sys-svc-container/templates/healthcheck/tcp.yml.j2' %}
    {{ lookup('container_image', application_id, 'talk') }}
    {{ lookup('compose_only', 'container_name', NEXTCLOUD_HPB_CONTAINER) }}
    init: true
    {% if NEXTCLOUD_HPB_NETWORK_MODE == 'bridge' %}
    {% if NEXTCLOUD_HPB_TURN_ONBOARD_ENABLED | bool and NEXTCLOUD_HPB_TURN_ONBOARD_PUBLISH_PORTS | bool %}
    ports:
      - {{ NEXTCLOUD_HPB_TURN_ONBOARD_BIND_HOST }}:{{ NEXTCLOUD_HPB_TURN_ONBOARD_PORT }}:{{ NEXTCLOUD_HPB_TURN_ONBOARD_PORT }}/tcp # nocheck: compose-ports-must-use-container-ports
      - {{ NEXTCLOUD_HPB_TURN_ONBOARD_BIND_HOST }}:{{ NEXTCLOUD_HPB_TURN_ONBOARD_PORT }}:{{ NEXTCLOUD_HPB_TURN_ONBOARD_PORT }}/udp # nocheck: compose-ports-must-use-container-ports
      - {{ NEXTCLOUD_HPB_TURN_ONBOARD_BIND_HOST }}:{{ NEXTCLOUD_HPB_TURN_ONBOARD_RELAY_PORT_START }}-{{ NEXTCLOUD_HPB_TURN_ONBOARD_RELAY_PORT_END }}:{{ NEXTCLOUD_HPB_TURN_ONBOARD_RELAY_PORT_START }}-{{ NEXTCLOUD_HPB_TURN_ONBOARD_RELAY_PORT_END }}/udp # nocheck: compose-ports-must-use-container-ports
      - {{ NEXTCLOUD_HPB_TURN_ONBOARD_BIND_HOST }}:{{ NEXTCLOUD_HPB_TURN_ONBOARD_RELAY_PORT_START }}-{{ NEXTCLOUD_HPB_TURN_ONBOARD_RELAY_PORT_END }}:{{ NEXTCLOUD_HPB_TURN_ONBOARD_RELAY_PORT_START }}-{{ NEXTCLOUD_HPB_TURN_ONBOARD_RELAY_PORT_END }}/tcp # nocheck: compose-ports-must-use-container-ports
    {% endif %}
    expose:
      - "{{ container_port }}"
    {{ lookup('container_networks') | indent(4) }}
    {% else %}
    network_mode: {{ NEXTCLOUD_HPB_NETWORK_MODE }}
    {% endif %}
  {% endif %}

  {% if NEXTCLOUD_WHITEBOARD_ENABLED %}
  {% set service_name = NEXTCLOUD_WHITEBOARD_SERVICE %}
  {% set container_port = NEXTCLOUD_WHITEBOARD_PORT_INTERNAL %}
  {{ service_name }}:
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    build:
      context: .
      dockerfile: {{ NEXTCLOUD_WHITEBOARD_SERVICE_DOCKERFILE }}
    {{ lookup('compose_only', 'pull_policy', 'never') }}
    {{ lookup('container_image', application_id, 'whiteboard') }}
    {% include 'roles/sys-svc-container/templates/healthcheck/nc.yml.j2' %}
    {{ lookup('compose_only', 'container_name', NEXTCLOUD_WHITEBOARD_CONTAINER) }}
    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
    environment:
      - NODE_OPTIONS=--max-old-space-size={{ NEXTCLOUD_WHITEBOARD_MAX_OLD_SPACE_SIZE }}
    expose:
      - "{{ container_port }}"
    shm_size: 1g
    {{ lookup('container_networks') | indent(4) }}
    {%+ if lookup('engine', 'redis', application_id, 'local') %}{{ lookup('depends_on', {'redis': 'service_healthy'}) }}{% endif %}
  {% endif %}


  {% set service_name = NEXTCLOUD_CRON_SERVICE %}
  {{ service_name }}:
    {% include 'roles/sys-svc-container/templates/deploy.yml.j2' %}
    {{ lookup('compose_only', 'container_name', NEXTCLOUD_CRON_CONTAINER) }}
    {{ lookup('container_image', application_id, 'nextcloud') }}
    {{ lookup('compose_restart') }}
    logging:
      driver: journald
    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
    entrypoint: /cron.sh
    sysctls:
      net.ipv6.conf.all.disable_ipv6: "{{ (not NETWORK_IPV6_ENABLED | bool) | int }}"
    healthcheck:
      test: ["CMD", "su", "www-data", "-s", "/bin/sh", "-c", "php {{ NEXTCLOUD_INTERNAL_OCC_COMMAND }} status"]
      interval: 1m
      timeout: 30s
      retries: 10
      start_period: {{ container_healthcheck_start_period }}
    {{ lookup('container_depends_on', application_id) | indent(4) }}
    {{ lookup('container_networks') | indent(4) }}

  {% if NEXTCLOUD_RECORDING_ENABLED | bool %}
  {% set service_name = 'talk_recording' %}
  {{ service_name }}:
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_image', application_id, 'talk_recording') }}
    {{ lookup('compose_only', 'container_name', NEXTCLOUD_RECORDING_CONTAINER) }}
    environment:
      - HPB_DOMAIN={{ NEXTCLOUD_HPB_DOMAIN }}
      - NC_DOMAIN={{ NEXTCLOUD_DOMAIN }}
      - RECORDING_SECRET={{ NEXTCLOUD_RECORDING_SECRET }}
      - INTERNAL_SECRET={{ NEXTCLOUD_HPB_INTERNAL_SECRET }}
      - TZ={{ HOST_TIMEZONE }}
    expose:
      - "{{ NEXTCLOUD_RECORDING_PORT }}"
    {{ lookup('container_networks') | indent(4) }}
    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
  {% endif %}

{% set _extra_volumes = {'data': {'name': NEXTCLOUD_VOLUME}} %}
{% if NEXTCLOUD_WHITEBOARD_ENABLED %}
{%   set _ = _extra_volumes.update({
        'whiteboard_tmp':      {'name': NEXTCLOUD_WHITEBOARD_TMP_VOLUME},
        'whiteboard_fontcache': {'name': NEXTCLOUD_WHITEBOARD_FRONTCACHE_VOLUME}
      }) %}
{% endif %}
{% if NEXTCLOUD_RECORDING_ENABLED | bool %}
{%   set _ = _extra_volumes.update({'talk_recording_tmp': {'name': NEXTCLOUD_RECORDING_TMP_VOLUME}}) %}
{% endif %}
{{ lookup('compose_volumes', application_id,
    extra_volumes=_extra_volumes
) }}

{{ lookup('compose_networks') }}
