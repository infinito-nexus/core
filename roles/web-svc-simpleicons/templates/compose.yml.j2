{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}
  {% set service_name = 'simpleicons' %}
  {{ service_name }}:
    {{ lookup('template', 'roles/sys-svc-container/templates/build.yml.j2') | indent(4) }}
      args:
        SIMPLEICONS_IMAGE: "{{ SIMPLEICONS_IMAGE }}"
        SIMPLEICONS_VERSION: "{{ SIMPLEICONS_VERSION }}"
        container_port: "{{ container_port | string }}"
    {{ lookup('container_image', application_id, 'simpleicons', image=SIMPLEICONS_LOCAL_IMAGE, version=SIMPLEICONS_LOCAL_VERSION) }}
    {{ lookup('compose_only', 'container_name', "simpleicons-server") }}
    {{ lookup('container_ports', ['simpleicons', 'http', DOCKER_BIND_HOST]) | indent(4) }}
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_networks') | indent(4) }}
    {% include 'roles/sys-svc-container/templates/healthcheck/curl.yml.j2' %}

{{ lookup('compose_volumes', application_id) }}

{{ lookup('compose_networks') }}
