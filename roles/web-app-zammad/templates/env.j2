{% include 'roles/sys-svc-container/templates/env.j2' %}

POSTGRESQL_HOST={{ lookup('database', application_id, 'host') }}
POSTGRESQL_PORT={{ lookup('database', application_id, 'port') }}
POSTGRESQL_DB={{ lookup('database', application_id, 'name') }}
POSTGRESQL_USER={{ lookup('database', application_id, 'username') }}
POSTGRESQL_PASS={{ lookup('database', application_id, 'password') | dotenv_quote }}
DATABASE_URL=postgres://{{ lookup('database', application_id, 'username') }}:{{ lookup('database', application_id, 'password') | urlencode }}@{{ lookup('database', application_id, 'host') }}:{{ lookup('database', application_id, 'port') }}/{{ lookup('database', application_id, 'name') }}

REDIS_URL={{ lookup('engine', 'redis', application_id, 'url') }}

MEMCACHE_SERVERS={{ lookup('engine', 'memcached', application_id, 'host') }}:{{ lookup('engine', 'memcached', application_id, 'port') }}

ELASTICSEARCH_HOST={{ ZAMMAD_SEARCH_SERVICE }}
ELASTICSEARCH_PORT={{ ZAMMAD_SEARCH_PORT }}
ELASTICSEARCH_SCHEMA=http
ELASTICSEARCH_NAMESPACE=zammad
ELASTICSEARCH_REINDEX=true

RAILS_ENV=production
RAILS_LOG_TO_STDOUT=true
RAILS_EAGER_LOAD=false
NGINX_SERVER_NAME={{ ZAMMAD_HOSTNAME }}
NGINX_SERVER_SCHEME={{ ZAMMAD_WEB_PROTOCOL }}
ZAMMAD_RAILSSERVER_HOST={{ ZAMMAD_RAILS_SERVICE }}
ZAMMAD_RAILSSERVER_PORT={{ ZAMMAD_RAILS_PORT }}
ZAMMAD_WEBSOCKET_HOST={{ ZAMMAD_WEBSOCKET_SERVICE }}
ZAMMAD_WEBSOCKET_PORT={{ ZAMMAD_WEBSOCKET_PORT }}

ZAMMAD_WEB_CONCURRENCY=0
ZAMMAD_SECRET_KEY_BASE={{ ZAMMAD_SECRET_KEY_BASE | dotenv_quote }}

RAILS_TRUSTED_PROXIES={{ NETWORK_TRUSTED_PROXY_CIDRS | join(',') }}
