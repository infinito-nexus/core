{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

  {{ ZAMMAD_INIT_CONTAINER }}:
    image: "{{ ZAMMAD_IMAGE }}:{{ ZAMMAD_VERSION }}"
    container_name: "{{ ZAMMAD_INIT_CONTAINER }}"
{% set docker_restart_policy = 'on-failure' %}
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    command: ["zammad-init"]
    volumes:
      - zammad_storage:/opt/zammad/storage
      - "{{ ZAMMAD_AUTO_WIZARD_HOST_PATH }}:/opt/zammad/auto_wizard.json:ro"
{{ lookup('container_depends_on', application_id) }}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}

  {{ ZAMMAD_RAILS_CONTAINER }}:
    image: "{{ ZAMMAD_IMAGE }}:{{ ZAMMAD_VERSION }}"
    container_name: "{{ ZAMMAD_RAILS_CONTAINER }}"
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    command: ["zammad-railsserver"]
    depends_on:
      {{ ZAMMAD_INIT_CONTAINER }}:
        condition: service_completed_successfully
    volumes:
      - zammad_storage:/opt/zammad/storage
      - "{{ ZAMMAD_OMNIAUTH_INIT_HOST_PATH }}:{{ ZAMMAD_OMNIAUTH_INIT_CONTAINER_PATH }}:ro"
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}

  {{ ZAMMAD_WEBSOCKET_CONTAINER }}:
    image: "{{ ZAMMAD_IMAGE }}:{{ ZAMMAD_VERSION }}"
    container_name: "{{ ZAMMAD_WEBSOCKET_CONTAINER }}"
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    command: ["zammad-websocket"]
    depends_on:
      {{ ZAMMAD_RAILS_CONTAINER }}:
        condition: service_started
    volumes:
      - zammad_storage:/opt/zammad/storage
      - "{{ ZAMMAD_OMNIAUTH_INIT_HOST_PATH }}:{{ ZAMMAD_OMNIAUTH_INIT_CONTAINER_PATH }}:ro"
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}

  {{ ZAMMAD_SCHEDULER_CONTAINER }}:
    image: "{{ ZAMMAD_IMAGE }}:{{ ZAMMAD_VERSION }}"
    container_name: "{{ ZAMMAD_SCHEDULER_CONTAINER }}"
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    command: ["zammad-scheduler"]
    depends_on:
      {{ ZAMMAD_RAILS_CONTAINER }}:
        condition: service_started
    volumes:
      - zammad_storage:/opt/zammad/storage
      - "{{ ZAMMAD_OMNIAUTH_INIT_HOST_PATH }}:{{ ZAMMAD_OMNIAUTH_INIT_CONTAINER_PATH }}:ro"
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}

  {{ ZAMMAD_SEARCH_CONTAINER }}:
    image: "{{ ZAMMAD_SEARCH_IMAGE }}:{{ ZAMMAD_SEARCH_VERSION }}"
    container_name: "{{ ZAMMAD_SEARCH_CONTAINER }}"
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    environment:
      - discovery.type=single-node
      - xpack.security.enabled=false
      - ES_JAVA_OPTS=-Xms512m -Xmx512m
    volumes:
      - zammad_search:/usr/share/elasticsearch/data
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}

  {{ ZAMMAD_MEMCACHED_CONTAINER }}:
    image: "{{ ZAMMAD_MEMCACHED_IMAGE }}:{{ ZAMMAD_MEMCACHED_VERSION }}"
    container_name: "{{ ZAMMAD_MEMCACHED_CONTAINER }}"
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    command: ["memcached", "-m", "256"]
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}

  {{ ZAMMAD_NGINX_CONTAINER }}:
    image: "{{ ZAMMAD_IMAGE }}:{{ ZAMMAD_VERSION }}"
    container_name: "{{ ZAMMAD_NGINX_CONTAINER }}"
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    # Patch zammad-nginx entrypoint to match only literal `nameserver` lines in
    # /etc/resolv.conf — Docker writes comment lines like `# Overrides: …` that
    # the upstream `grep "nameserver"` matches as substrings, yielding an
    # invalid `resolver … Overrides: …` directive that nginx rejects. The
    # upstream script is read-only for the zammad user, so we patch a copy in
    # /tmp and exec that.
    command:
      - sh
      - -c
      - |
        cp /docker-entrypoint.sh /tmp/entrypoint-patched.sh
        sed -i 's|grep "nameserver" < /etc/resolv.conf|grep -E "^nameserver" /etc/resolv.conf|' /tmp/entrypoint-patched.sh
        exec /tmp/entrypoint-patched.sh zammad-nginx
    depends_on:
      {{ ZAMMAD_RAILS_CONTAINER }}:
        condition: service_started
      {{ ZAMMAD_WEBSOCKET_CONTAINER }}:
        condition: service_started
    ports:
      - "{{ DOCKER_BIND_HOST }}:{{ lookup('config', application_id, 'services.zammad.ports.local.http') }}:8080"
    volumes:
      - zammad_storage:/opt/zammad/storage
      - "{{ ZAMMAD_OMNIAUTH_INIT_HOST_PATH }}:{{ ZAMMAD_OMNIAUTH_INIT_CONTAINER_PATH }}:ro"
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}

{{ lookup('applications') | compose_volumes(
    application_id,
    extra_volumes={'zammad_storage': {}, 'zammad_search': {}}
) }}
{% include 'roles/sys-svc-compose/templates/networks.yml.j2' %}
