{# This template needs to be included in compose.yml, which depend on a mariadb database #}
{% if lookup('database', application_id, 'local') %}

  {{ lookup('database', application_id, 'host') }}:
    {{ lookup('compose_only', 'container_name', ((application_id | get_entity_name) ~ '-database')) }}
    logging:
      driver: journald
    {{ lookup('container_image', 'svc-db-mariadb', 'mariadb', version=lookup('database', application_id, 'version')) }}
    {{ lookup('compose_restart') }}
    env_file:
      - {{ lookup('database', application_id, 'env') }}
    command: "--transaction-isolation=READ-COMMITTED --binlog-format=ROW"
    volumes:
      - database:/var/lib/mysql
    healthcheck:
      test: [ "CMD", "sh", "-c", "/usr/bin/mariadb --user=$$MYSQL_USER --password=$$MYSQL_PASSWORD --execute 'SHOW DATABASES;'" ]
      interval: 10s
      timeout: 5s
      retries: 18
    networks:  # nocheck: networks-literal  local sidecar inside consumer stack, default-only attachment
      - default
{% endif %}
{{ "\n" }}