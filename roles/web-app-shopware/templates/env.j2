{% include 'roles/sys-svc-container/templates/env.j2' %}

DOMAIN={{ SHOPWARE_DOMAIN }}
APP_URL={{ lookup('tls', application_id, 'url.base') }}
APP_DEBUG={{ MODE_DEBUG | bool| ternary(1, 0) }}

APP_ENV={{ 'dev' if (ENVIRONMENT | lower) == 'development' else 'prod' }}
INSTANCE_ID={{ application_id }}
SHOPWARE_OBJSTORE_ENABLED={{ SHOPWARE_OBJSTORE_ENABLED | string | lower }}
SHOPWARE_OBJSTORE_ENDPOINT={{ lookup('objstore', application_id, 'url') }}

TRUSTED_PROXIES={{ ([networks.internet.values() | select | list, NETWORK_TRUSTED_PROXY_CIDRS] | flatten) | join(',') }}
TRUSTED_HOSTS={{ SHOPWARE_DOMAIN }}

DATABASE_URL=mysql://{{ lookup('database', application_id, 'username') }}:{{ lookup('database', application_id, 'password') }}@{{ lookup('database', application_id, 'host') }}:{{ lookup('database', application_id, 'port') }}/{{ lookup('database', application_id, 'name') }}

{% if SHOPWARE_REDIS_ENABLED | bool %}
REDIS_URL={{ SHOPWARE_REDIS_URL }}/0
CACHE_URL={{ SHOPWARE_REDIS_URL }}/1
MESSENGER_TRANSPORT_DSN={{ SHOPWARE_REDIS_URL }}/2
{% set _redis_user = lookup('engine', 'redis', application_id, 'username') %}
{% set _redis_password = lookup('engine', 'redis', application_id, 'password') %}
{% set _session_host = lookup('engine', 'redis', application_id, 'host') ~ ':' ~ lookup('engine', 'redis', application_id, 'port') %}
{% if _redis_password | length > 0 and _redis_user | length > 0 %}
REDIS_SESSION_TARGET=tcp://{{ _session_host }}?database=3&auth[user]={{ _redis_user | urlencode }}&auth[pass]={{ _redis_password | urlencode }}
{% elif _redis_password | length > 0 %}
REDIS_SESSION_TARGET=tcp://{{ _session_host }}?database=3&auth={{ _redis_password | urlencode }}
{% else %}
REDIS_SESSION_TARGET=tcp://{{ _session_host }}?database=3
{% endif %}
{% else %}
CACHE_URL=file://cache
{% endif %}

{% if SHOPWARE_OPENSEARCH_ENABLED %}
ELASTICSEARCH_URL=http://opensearch:{{ SHOPWARE_OPENSEARCH_PORT }}
OPENSEARCH_URL=http://opensearch:{{ SHOPWARE_OPENSEARCH_PORT }}
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT_NUMBER={{ SHOPWARE_OPENSEARCH_PORT }}
OPENSEARCH_INITIAL_ADMIN_PASSWORD={{ SHOPWARE_OPENSEARCH_INITIAL_ADMIN_PASSWORD | dotenv_quote }}
{% endif %}

{% set email = lookup('email', application_id) %}
{% if email.enabled | bool %}
MAILER_DSN=smtps://{{ email.username }}:{{ email.password }}@{{ email.host }}:{{ email.port }}
{% endif %}
