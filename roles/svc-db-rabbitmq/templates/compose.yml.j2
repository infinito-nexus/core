{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}
  {% set service_name = 'rabbitmq' %}
  {{ service_name }}:
    {{ lookup('compose_only', 'container_name', RABBITMQ_CONTAINER) }}
    {{ lookup('container_image', application_id, 'rabbitmq') }}
    hostname: "{{ RABBITMQ_CONTAINER }}"

    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {% if RABBITMQ_EXPOSE_LOCAL %}
    {{ lookup('container_ports', ['rabbitmq', 'rabbitmq', DOCKER_BIND_HOST]) | indent(4) }}
    {% endif %}
    {{ lookup('container_volumes', application_id, 'rabbitmq') | indent(4) }}
    {{ lookup('container_networks') | indent(4) }}
    healthcheck:
      test:
        - "CMD-SHELL"
        - "rabbitmq-diagnostics -q ping || exit 1"
      interval: 10s
      timeout: 5s
      retries: 18
      start_period: 60s

{{ lookup('compose_volumes', application_id) }}
{{ lookup('compose_networks') }}
