{% include 'roles/sys-svc-container/templates/env.j2' %}

PGADMIN_DISABLE_POSTFIX=True

PGADMIN_DEFAULT_EMAIL={{ lookup('config', application_id, 'users.administrator.email') }}

# Accept the deployment TLD even when it is special-use (e.g. `.test` in
# dev/CI); email_validator otherwise rejects the login email at startup.
PGADMIN_CONFIG_ALLOW_SPECIAL_EMAIL_DOMAINS=['{{ DOMAIN_PRIMARY.split('.') | last }}']

# Default login password for server mode
PGADMIN_DEFAULT_PASSWORD={{ lookup('config', application_id, 'credentials.administrator_password') | dotenv_quote }}

{% if PGADMIN_SERVER_MODE | bool %}
PGADMIN_SERVER_JSON_FILE={{ pgadmin_docker_server_file }}

PGADMIN_CONFIG_SERVER_MODE=False

PGADMIN_CONFIG_MASTER_PASSWORD_REQUIRED={{ PGADMIN_MASTER_PASSWORD_REQUIRED | capitalize | dotenv_quote }}
{% endif %}

{% set email = lookup('email', application_id) %}
{% if email.enabled | bool %}
PGADMIN_CONFIG_MAIL_SERVER={{ email.host | tojson | dotenv_quote }}
PGADMIN_CONFIG_MAIL_PORT={{ email.port }}
PGADMIN_CONFIG_MAIL_USE_SSL={{ email.tls | string | capitalize | dotenv_quote }}
PGADMIN_CONFIG_MAIL_USE_TLS={{ email.start_tls | string | capitalize | dotenv_quote }}
PGADMIN_CONFIG_MAIL_USERNAME={{ email.username | tojson | dotenv_quote }}
PGADMIN_CONFIG_MAIL_PASSWORD={{ email.password | tojson | dotenv_quote }}
PGADMIN_CONFIG_MAIL_DEFAULT_SENDER={{ email['from'] | tojson | dotenv_quote }}
{% endif %}
