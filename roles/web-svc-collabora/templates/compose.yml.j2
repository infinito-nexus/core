{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

  {% set container_healthcheck = COLLABORA_DISCOVERY_PATH | regex_replace('^/+', '') %}
  {% set service_name = 'collabora' %}
  {{ service_name }}:
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_image', application_id, 'collabora') }}
    {{ lookup('compose_only', 'container_name', COLLABORA_CONTAINER) }}
    security_opt:
      - seccomp=unconfined
      - apparmor=unconfined
    cap_add:
      - SYS_ADMIN
      - MKNOD
      - SYS_CHROOT
      - SETUID
      - SETGID
      - FOWNER
    {{ lookup('container_ports', ['collabora', 'http', DOCKER_BIND_HOST]) | indent(4) }}
    {% include 'roles/sys-svc-container/templates/healthcheck/tcp.yml.j2' %}
    {{ lookup('container_networks') | indent(4) }}

{{ lookup('compose_volumes', application_id) }}

{{ lookup('compose_networks') }}
