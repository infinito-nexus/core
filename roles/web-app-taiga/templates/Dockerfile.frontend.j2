# ── Stage 1: Build taiga-contrib-oidc-auth frontend plugin ───────────────────
# Node 16 matches .nvmrc of taiga-contrib-oidc-auth
FROM {{ TAIGA_OIDC_FRONTEND_BUILDER_IMAGE }}:{{ TAIGA_OIDC_FRONTEND_BUILDER_VERSION }} AS plugin-builder

RUN apk add --no-cache git

WORKDIR /build
RUN git clone {{ TAIGA_OIDC_PLUGIN_REPOSITORY }} . && \
    git checkout {{ TAIGA_OIDC_PLUGIN_REF }}

WORKDIR /build/front
RUN npm install

RUN {{ TAIGA_OIDC_FRONTEND_BUILD_COMMAND }}

FROM taigaio/taiga-front:{{ TAIGA_VERSION }}

COPY --from=plugin-builder /build/front/dist/ /usr/share/nginx/html/plugins/oidc-auth/
