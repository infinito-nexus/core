TAIGA_SITES_SCHEME={{ lookup('tls', application_id, 'protocols.web') }}
TAIGA_SITES_DOMAIN={{ lookup('domain',application_id) }}

TAIGA_SUBPATH=
WEBSOCKETS_SCHEME={{ lookup('tls', application_id, 'protocols.websocket') }}

TAIGA_SECRET_KEY={{ lookup('config', application_id, 'credentials.secret_key') }}
SECRET_KEY={{ lookup('config', application_id, 'credentials.secret_key') }}

POSTGRES_USER={{ lookup('database', application_id, 'username') }}
POSTGRES_PASSWORD={{ lookup('database', application_id, 'password') | dotenv_quote }}
POSTGRES_DB={{ lookup('database', application_id, 'name') }}
POSTGRES_HOST={{ lookup('database', application_id, 'host') }}

{% set email = lookup('email', application_id) %}
{% if email.enabled | bool %}
EMAIL_BACKEND={{ TAIGA_EMAIL_BACKEND }}
EMAIL_HOST={{ email.host }}
EMAIL_PORT={{ email.port }}
EMAIL_HOST_USER={{ email.username }}
EMAIL_HOST_PASSWORD={{ email.password | dotenv_quote }}
EMAIL_DEFAULT_FROM={{ email['from'] }}
DEFAULT_FROM_EMAIL={{ email['from'] }}

EMAIL_USE_TLS={{ email.tls | capitalize }}
EMAIL_USE_SSL={{ 'False' if email.start_tls else 'True' }}
{% endif %}

RABBITMQ_USER=taiga
RABBITMQ_PASS=taiga
RABBITMQ_VHOST=taiga

RABBITMQ_DEFAULT_USER=taiga
RABBITMQ_DEFAULT_PASS=taiga
RABBITMQ_DEFAULT_VHOST=taiga
RABBITMQ_ERLANG_COOKIE=secret-erlang-cookie

ATTACHMENTS_MAX_AG=360
MAX_AGE=360

ENABLE_TELEMETRY=False
