{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

{% set TAIGA_BACKEND_AUTH_BUILD_PROPS -%}
build:
  context: "{{ compose_repository_path }}"
  dockerfile: Dockerfile.taiga-back
image: "{{ TAIGA_DOCKER_IMAGE_BACKEND_AUTH }}"
{{ lookup('compose_only', 'pull_policy', 'never') }}
{%- endset %}

{% set service_name = TAIGA_SERVICE %}
  {{ service_name }}:
    {{ lookup('compose_only', 'container_name', TAIGA_CONTAINER) }}
    hostname:       {{ TAIGA_HOSTNAME }}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    healthcheck:
      test: ["CMD", "python", "-c", "import socket; socket.create_connection(('127.0.0.1',8000),5).close()"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 40s
{% if TAIGA_PLUGINS_ENABLED | bool %}
{{ TAIGA_BACKEND_AUTH_BUILD_PROPS | indent(4, true) }}
    entrypoint: ["/bin/sh", "-c"]
    command:
      - "if ! grep -qF {{ TAIGA_CONFIG_APPEND_MARKER | quote }} /taiga-back/settings/config.py; then cat /taiga-back/settings/config.append.py >> /taiga-back/settings/config.py; fi; exec /taiga-back/docker/entrypoint.sh"
{% else %}
    image: "{{ TAIGA_DOCKER_IMAGE_BACKEND }}:{{ TAIGA_VERSION }}"
{% endif %}
    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
      taiga:
{{ lookup('container_depends_on', application_id, extra={
  TAIGA_EVENTS_RABBITMQ_SERVICE: {'condition': 'service_started'},
  TAIGA_ASYNC_RABBITMQ_SERVICE: {'condition': 'service_started'},
}) }}

{% set service_name = TAIGA_ASYNC_SERVICE %}
  {{ service_name }}:
    {{ lookup('compose_only', 'container_name', TAIGA_CONTAINER ~ '-' ~ service_name) }}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    healthcheck:
      test: ["CMD-SHELL", "tr '\\0' ' ' </proc/1/cmdline | grep -qi celery"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 60s
{% if TAIGA_PLUGINS_ENABLED | bool %}
{{ TAIGA_BACKEND_AUTH_BUILD_PROPS | indent(4, true) }}
    entrypoint: ["/bin/sh", "-c"]
    command:
      - "if ! grep -qF {{ TAIGA_CONFIG_APPEND_MARKER | quote }} /taiga-back/settings/config.py; then cat /taiga-back/settings/config.append.py >> /taiga-back/settings/config.py; fi; exec /taiga-back/docker/async_entrypoint.sh"
{% else %}
    image: "{{ TAIGA_DOCKER_IMAGE_BACKEND }}:{{ TAIGA_VERSION }}"
    entrypoint: ["/taiga-back/docker/async_entrypoint.sh"]
{% endif %}
    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
      taiga:
{{ lookup('container_depends_on', application_id, extra={
  TAIGA_EVENTS_RABBITMQ_SERVICE: {'condition': 'service_started'},
  TAIGA_ASYNC_RABBITMQ_SERVICE: {'condition': 'service_started'},
}) }}

{% set service_name = TAIGA_ASYNC_RABBITMQ_SERVICE %}
  {{ service_name }}:
    {{ lookup('compose_only', 'container_name', TAIGA_CONTAINER ~ '-' ~ service_name) }}
    image: "{{ TAIGA_DOCKER_IMAGE_ASYNC_RABBITMQ }}:{{ TAIGA_DOCKER_VERSION_ASYNC_RABBITMQ }}"
    hostname: "{{ TAIGA_ASYNC_RABBITMQ_SERVICE }}"
    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    healthcheck:
      test: ["CMD", "rabbitmq-diagnostics", "-q", "ping"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 20s
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
      taiga:

{% set service_name = TAIGA_FRONT_SERVICE %}
{% set container_port = 80 %}
  {{ service_name }}:
    {{ lookup('compose_only', 'container_name', TAIGA_CONTAINER ~ '-' ~ service_name) }}
{% if TAIGA_OIDC_ENABLED | bool %}
    build:
      context: "{{ compose_repository_path }}"
      dockerfile: Dockerfile.taiga-front
    image: "{{ TAIGA_DOCKER_IMAGE_FRONTEND_OIDC }}"
    {{ lookup('compose_only', 'pull_policy', 'never') }}
{% else %}
    image: "{{ TAIGA_DOCKER_IMAGE_FRONTEND }}:{{ TAIGA_VERSION }}"
{% endif %}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
{% filter indent(4) %}
    {% include 'roles/sys-svc-container/templates/healthcheck/http.yml.j2' %}
{% endfilter %}

    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
      taiga:

{% set service_name = TAIGA_EVENTS_SERVICE %}
  {{ service_name }}:
    {{ lookup('compose_only', 'container_name', TAIGA_CONTAINER ~ '-' ~ service_name) }}
    image: "{{ TAIGA_DOCKER_IMAGE_EVENTS }}:{{ TAIGA_DOCKER_VERSION_EVENTS }}"
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    healthcheck:
      test: ["CMD-SHELL", "nc -z 127.0.0.1 8888"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 30s
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
      taiga:
    {{ lookup('depends_on', {TAIGA_EVENTS_RABBITMQ_SERVICE: 'service_started'}) }}

{% set service_name = TAIGA_EVENTS_RABBITMQ_SERVICE %}
  {{ service_name }}:
    {{ lookup('compose_only', 'container_name', TAIGA_CONTAINER ~ '-' ~ service_name) }}
    image: "{{ TAIGA_DOCKER_IMAGE_EVENTS_RABBITMQ }}:{{ TAIGA_DOCKER_VERSION_EVENTS_RABBITMQ }}"
    hostname: {{ service_name }}
    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    healthcheck:
      test: ["CMD", "rabbitmq-diagnostics", "-q", "ping"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 20s
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
      taiga:

{% set service_name = 'protected' %}
  {{ service_name }}:
    {{ lookup('compose_only', 'container_name', TAIGA_CONTAINER ~ '-' ~ service_name) }}
    image: "{{ TAIGA_DOCKER_IMAGE_PROTECTED }}:{{ TAIGA_DOCKER_VERSION_PROTECTED }}"
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    healthcheck:
      test: ["CMD", "python", "-c", "import socket; socket.create_connection(('127.0.0.1',8003),5).close()"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 20s
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
      taiga:

{% set service_name = 'gateway' %}
{% set container_port = 80 %}
  {{ service_name }}:
    {{ lookup('compose_only', 'container_name', TAIGA_CONTAINER ~ '-' ~ service_name) }}
    image: "{{ TAIGA_DOCKER_IMAGE_GATEWAY }}:{{ TAIGA_DOCKER_VERSION_GATEWAY }}"
    ports:
      - "{{ DOCKER_BIND_HOST }}:{{ lookup('config', application_id, 'services.taiga.ports.local.http') }}:{{ container_port }}"
    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
{% filter indent(4) %}
    {% include 'roles/sys-svc-container/templates/healthcheck/http.yml.j2' %}
{% endfilter %}

{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
      taiga:
    {{ lookup('depends_on', [TAIGA_FRONT_SERVICE, TAIGA_SERVICE, TAIGA_EVENTS_SERVICE]) }}
{{ lookup('compose_volumes', application_id) }}
{% include 'roles/sys-svc-compose/templates/networks.yml.j2' %}
  taiga:
