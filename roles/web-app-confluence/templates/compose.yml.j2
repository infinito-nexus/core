{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}
  confluence:
    {{ lookup('template', 'roles/sys-svc-container/templates/build.yml.j2') | indent(4) }}
      args:
        CONFLUENCE_IMAGE: "{{ CONFLUENCE_IMAGE }}"
        CONFLUENCE_VERSION: "{{ CONFLUENCE_VERSION }}"
        CONFLUENCE_HOME: "{{ CONFLUENCE_HOME }}"
    {{ lookup('container_image', application_id, 'confluence', custom=True) }}
    {{ lookup('compose_only', 'container_name', CONFLUENCE_CONTAINER) }}
    hostname: '{{ CONFLUENCE_HOSTNAME}}'
    ports:
      - "{{ DOCKER_BIND_HOST }}:{{ lookup('config', application_id, 'services.confluence.ports.local.http') }}:{{ lookup('config', application_id, 'services.confluence.ports.internal.http') }}"
    {{ lookup('container_volumes', application_id, 'confluence') | indent(4) }}
{% include 'roles/sys-svc-container/templates/healthcheck/curl.yml.j2' %}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
{{ lookup('container_depends_on', application_id) }}
    {{ lookup('container_networks') | indent(4) }}

{{ lookup('compose_volumes', application_id) }}
{{ lookup('compose_networks') }}
