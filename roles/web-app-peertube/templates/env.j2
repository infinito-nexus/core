# Database / Postgres service configuration
POSTGRES_USER={{ lookup('database', application_id, 'username') }}
POSTGRES_PASSWORD={{ lookup('database', application_id, 'password') | dotenv_quote }}
POSTGRES_DB={{ lookup('database', application_id, 'name') }}
PEERTUBE_DB_USERNAME={{ lookup('database', application_id, 'username') }}
PEERTUBE_DB_PASSWORD={{ lookup('database', application_id, 'password') | dotenv_quote }}
PEERTUBE_DB_SSL=false
PEERTUBE_DB_HOSTNAME={{ lookup('database', application_id, 'host') }}

# PeerTube server configuration
PEERTUBE_WEBSERVER_HOSTNAME={{ lookup('domain',application_id) }}
PEERTUBE_TRUST_PROXY=["127.0.0.1", "loopback"]

PEERTUBE_SECRET={{ lookup('config', application_id, 'credentials.secret')}}

{% if lookup('objstore', application_id, 'enabled') | bool %}
{% set objstore_bucket = lookup('objstore', application_id, 'bucket') %}
{% set objstore_public_base = lookup('objstore', application_id, 'public_url') %}
PEERTUBE_OBJECT_STORAGE_ENABLED=true
PEERTUBE_OBJECT_STORAGE_ENDPOINT={{ lookup('objstore', application_id, 'url') }}
PEERTUBE_OBJECT_STORAGE_REGION={{ lookup('objstore', application_id, 'region') }}
PEERTUBE_OBJECT_STORAGE_FORCE_PATH_STYLE=true
PEERTUBE_OBJECT_STORAGE_UPLOAD_ACL_PUBLIC=public-read
PEERTUBE_OBJECT_STORAGE_UPLOAD_ACL_PRIVATE=private
PEERTUBE_OBJECT_STORAGE_CREDENTIALS_ACCESS_KEY_ID={{ lookup('objstore', application_id, 'access_key') }}
PEERTUBE_OBJECT_STORAGE_CREDENTIALS_SECRET_ACCESS_KEY={{ lookup('objstore', application_id, 'secret_key') | dotenv_quote }}
PEERTUBE_OBJECT_STORAGE_WEB_VIDEOS_BUCKET_NAME={{ objstore_bucket }}
PEERTUBE_OBJECT_STORAGE_WEB_VIDEOS_PREFIX=web-videos/
PEERTUBE_OBJECT_STORAGE_WEB_VIDEOS_BASE_URL={{ objstore_public_base }}
PEERTUBE_OBJECT_STORAGE_STREAMING_PLAYLISTS_BUCKET_NAME={{ objstore_bucket }}
PEERTUBE_OBJECT_STORAGE_STREAMING_PLAYLISTS_PREFIX=streaming-playlists/
PEERTUBE_OBJECT_STORAGE_STREAMING_PLAYLISTS_BASE_URL={{ objstore_public_base }}
{% endif %}

{% set email = lookup('email', application_id) %}
{% if email.enabled | bool %}
# E-mail configuration
PEERTUBE_SMTP_USERNAME={{ email.username }}
PEERTUBE_SMTP_PASSWORD={{ email.password | dotenv_quote }}
PEERTUBE_SMTP_HOSTNAME={{ email.host }}
PEERTUBE_SMTP_PORT={{ email.port }}
PEERTUBE_SMTP_FROM={{ email['from'] }}
PEERTUBE_SMTP_TLS={{ email.tls | lower }}
PEERTUBE_SMTP_DISABLE_STARTTLS={{ 'false' if email.start_tls else 'true' }}
{% endif %}

PEERTUBE_ADMIN_EMAIL={{ email['from'] }}