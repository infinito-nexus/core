{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

  application:
{% set container_port = 9000 %}
    image: {{ PEERTUBE_IMAGE }}:{{ PEERTUBE_VERSION }}
    {{ lookup('compose_only', 'container_name', PEERTUBE_CONTAINER) }}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    ports:
     - "1935:1935"
     - "{{ DOCKER_BIND_HOST }}:{{ lookup('config', application_id, 'services.peertube.ports.local.http') }}:{{ container_port }}" 
    {{ lookup('container_volumes', application_id, 'application') | indent(4) }}
    environment:
      - NODE_OPTIONS=--max-old-space-size={{ PEERTUBE_MAX_OLD_SPACE_SIZE }}
      - PEERTUBE_TRANSCODING_CONCURRENCY={{ PEERTUBE_TRANSCODING_CONCURRENCY }}
    shm_size: "512m"
    tmpfs:
      - /tmp:size=1g,exec
    ulimits:
      nofile:
        soft: 131072
        hard: 131072
      nproc:  8192
{{ lookup('container_depends_on', application_id) }}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
{% include 'roles/sys-svc-container/templates/healthcheck/tcp.yml.j2' %}
{{ lookup('compose_volumes', application_id) }}
{% include 'roles/sys-svc-compose/templates/networks.yml.j2' %}
