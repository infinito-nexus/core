{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

{% set service_name = SUITECRM_SERVICE %}
  {{ service_name }}:
    {{ lookup('template', 'roles/sys-svc-container/templates/build.yml.j2') | indent(4) }}
      args:
        SUITECRM_BASE_IMAGE: "{{ SUITECRM_BASE_IMAGE }}"
        SUITECRM_BASE_VERSION: "{{ SUITECRM_BASE_VERSION }}"
        SUITECRM_APP_VERSION: "{{ SUITECRM_APP_VERSION }}"
        SUITECRM_ENTRYPOINT_SCRIPT_HOST_REL: "{{ SUITECRM_ENTRYPOINT_SCRIPT_HOST_REL }}"
        SUITECRM_ENTRYPOINT_SCRIPT_DOCKER: "{{ SUITECRM_ENTRYPOINT_SCRIPT_DOCKER }}"
        SUITECRM_LDAP_EXTENSION_DIR: "{{ SUITECRM_LDAP_EXTENSION_DIR }}"
    {{ lookup('compose_only', 'container_name', SUITECRM_CONTAINER) }}
    image: "{{ SUITECRM_CUSTOM_IMAGE }}"
    init: true
    stop_signal: SIGTERM
    stop_grace_period: 30s
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
{% include 'roles/sys-svc-container/templates/healthcheck/curl.yml.j2' %}
    ports:
      - "{{ DOCKER_BIND_HOST }}:{{ lookup('config', application_id, 'services.suitecrm.ports.local.http') }}:80"
{{ lookup('container_depends_on', application_id) }}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
{% set _extra_mounts = [] %}
{% if SUITECRM_LDAP_ENABLED | bool %}
{%   set _ = _extra_mounts.append(SUITECRM_LDAP_CONFIG_HOST ~ ':' ~ SUITECRM_LDAP_EXTENSION_DIR ~ '/ldap.yaml') %}
{% endif %}
    {{ lookup('container_volumes', application_id, service_name, extra_volumes=_extra_mounts) | indent(4) }}

{{ lookup('compose_volumes', application_id) }}
{% include 'roles/sys-svc-compose/templates/networks.yml.j2' %}
