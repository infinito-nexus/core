{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

  memcached:
    {{ lookup('compose_only', 'container_name', MEMCACHED_CONTAINER) }}
    {{ lookup('container_image', application_id, 'memcached') }}
    command:
      - "memcached"
      - "-m"
      - "{{ MEMCACHED_MEMORY_LIMIT_MB }}"

{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
{% if MEMCACHED_EXPOSE_LOCAL %}
    {{ lookup('container_ports', ['memcached', 'memcached', DOCKER_BIND_HOST]) | indent(4) }}
{% endif %}
    {{ lookup('container_networks') | indent(4) }}
    healthcheck:
      test:
        - "CMD-SHELL"
        - "printf 'version\\r\\n' | nc -w 1 127.0.0.1 11211 | grep -q VERSION"
      interval: 10s
      timeout: 5s
      retries: 18
      start_period: 15s

{{ lookup('compose_volumes', application_id) }}
{{ lookup('compose_networks') }}
