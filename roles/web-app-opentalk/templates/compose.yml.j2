{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

  application:
    image: "{{ OPENTALK_FRONTEND_IMAGE }}:{{ OPENTALK_FRONTEND_VERSION }}"
    {{ lookup('compose_only', 'container_name', OPENTALK_FRONTEND_CONTAINER) }}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    ports:
      - "{{ DOCKER_BIND_HOST }}:{{ OPENTALK_FRONTEND_HTTP_PORT }}:80"
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
    depends_on:
      controller:
        condition: service_started

  controller:
    image: "{{ OPENTALK_CTRL_IMAGE }}:{{ OPENTALK_CTRL_VERSION }}"
    {{ lookup('compose_only', 'container_name', OPENTALK_CTRL_CONTAINER) }}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    ports:
      - "{{ DOCKER_BIND_HOST }}:{{ OPENTALK_CTRL_HTTP_PORT }}:11311"
    volumes:
      - "{{ [lookup('container', application_id, 'directories.volumes'), 'controller.toml'] | path_join }}:/controller/controller.toml:ro"
      - data:/var/lib/opentalk
{{ lookup('container_depends_on', application_id) }}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}

{% set service_name = 'livekit' %}
  {{ service_name }}:
{% include 'roles/sys-svc-container/templates/deploy.yml.j2' %}
    image: "{{ OPENTALK_LIVEKIT_IMAGE }}:{{ OPENTALK_LIVEKIT_VERSION }}"
    {{ lookup('compose_only', 'container_name', OPENTALK_LIVEKIT_CONTAINER) }}
    {{ lookup('compose_restart') }}
    network_mode: host
    command:
      - --config
      - /etc/livekit/livekit.yaml
    volumes:
      - "{{ [lookup('container', application_id, 'directories.volumes'), 'livekit.yaml'] | path_join }}:/etc/livekit/livekit.yaml:ro"
    logging:
      driver: journald

{% set service_name = 'minio' %}
  {{ service_name }}:
{% include 'roles/sys-svc-container/templates/deploy.yml.j2' %}
    image: "{{ OPENTALK_MINIO_IMAGE }}:{{ OPENTALK_MINIO_VERSION }}"
    {{ lookup('compose_only', 'container_name', OPENTALK_MINIO_CONTAINER) }}
    {{ lookup('compose_restart') }}
    command: ["server", "/data"]
    environment:
      MINIO_ROOT_USER: "{{ OPENTALK_MINIO_USER }}"
      MINIO_ROOT_PASSWORD: "{{ OPENTALK_MINIO_PASSWORD }}"
    volumes:
      - minio:/data
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
    logging:
      driver: journald

{% set service_name = 'rabbit' %}
  {{ service_name }}:
{% include 'roles/sys-svc-container/templates/deploy.yml.j2' %}
    image: "{{ OPENTALK_RABBIT_IMAGE }}:{{ OPENTALK_RABBIT_VERSION }}"
    {{ lookup('compose_only', 'container_name', OPENTALK_RABBIT_CONTAINER) }}
    {{ lookup('compose_restart') }}
    environment:
      RABBITMQ_SERVER_ADDITIONAL_ERL_ARGS: "-rabbit consumer_timeout 30000"
    healthcheck:
      test: ["CMD", "rabbitmq-diagnostics", "ping"]
      interval: 30s
      timeout: 10s
      retries: 5
    volumes:
      - rabbit:/var/lib/rabbitmq
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
    logging:
      driver: journald

{% set service_name = 'recorder' %}
  {{ service_name }}:
{% include 'roles/sys-svc-container/templates/deploy.yml.j2' %}
    image: "{{ OPENTALK_RECORDER_IMAGE }}:{{ OPENTALK_RECORDER_VERSION }}"
    {{ lookup('compose_only', 'container_name', OPENTALK_RECORDER_CONTAINER) }}
    {{ lookup('compose_restart') }}
    volumes:
      - "{{ [lookup('container', application_id, 'directories.volumes'), 'recorder.toml'] | path_join }}:/recorder/recorder.toml:ro"
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
    depends_on:
      rabbit:
        condition: service_healthy
      controller:
        condition: service_started
    logging:
      driver: journald

{{ lookup('compose_volumes', application_id,
    extra_volumes={
      'data':   {'name': OPENTALK_DATA_VOLUME},
      'config': {'name': OPENTALK_CONFIG_VOLUME},
      'minio':  {'name': OPENTALK_MINIO_VOLUME},
      'rabbit': {'name': OPENTALK_RABBIT_VOLUME}
    }
) }}
{% include 'roles/sys-svc-compose/templates/networks.yml.j2' %}
