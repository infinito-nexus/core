{% include 'roles/sys-svc-container/templates/env.j2' %}

MOBILIZON_INSTANCE_NAME={{ lookup('config', application_id, 'services.mobilizon.titel') }}

MOBILIZON_INSTANCE_HOST={{ lookup('domain',application_id) }}

MOBILIZON_INSTANCE_PORT={{ container_port }}

MOBILIZON_INSTANCE_REGISTRATIONS_OPEN=false

{% set email = lookup('email', application_id) %}
{% if email.enabled | bool %}
MOBILIZON_INSTANCE_EMAIL={{ email['from'] }}
{% endif %}

MOBILIZON_REPLY_EMAIL={{ lookup('users', 'administrator').email }}

MOBILIZON_LOGLEVEL={% if MODE_DEBUG | bool %}debug{% else %}error{% endif %}

MOBILIZON_DATABASE_USERNAME={{ lookup('database', application_id, 'username') }}

MOBILIZON_DATABASE_PASSWORD={{ lookup('database', application_id, 'password') | dotenv_quote }}

MOBILIZON_DATABASE_DBNAME={{ lookup('database', application_id, 'name') }}

MOBILIZON_DATABASE_HOST={{ lookup('database', application_id, 'host') }}

MOBILIZON_DATABASE_PORT={{ lookup('database', application_id, 'port') }}

DATABASE_POOL_SIZE={{ POSTGRES_ALLOWED_AVG_CONNECTIONS }}
POOL_SIZE={{ POSTGRES_ALLOWED_AVG_CONNECTIONS }}

MOBILIZON_INSTANCE_SECRET_KEY_BASE={{ lookup('config', application_id, 'credentials.secret_key_base') }}

MOBILIZON_INSTANCE_SECRET_KEY={{ lookup('config', application_id, 'credentials.secret_key') }}

{% if email.enabled | bool %}
MOBILIZON_SMTP_SERVER={{ email.host }}
MOBILIZON_SMTP_PORT={{ email.port }}
MOBILIZON_SMTP_USERNAME={{ email.username }}
MOBILIZON_SMTP_PASSWORD={{ email.password | dotenv_quote }}

MOBILIZON_SMTP_SSL=false

MOBILIZON_INSTANCE_DISABLE_DATABASE_LOGIN={{ (lookup('config',application_id, 'services.ldap.enabled', False) or (MOBILIZON_OIDC_ENABLED | bool)) | lower }}

MOBILIZON_SMTP_TLS={% if email.tls | bool %}TLS{% elif email.start_tls | bool %}STARTTLS{% else %}Clear{% endif %}
{% endif %}
