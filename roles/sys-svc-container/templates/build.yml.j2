{# integrate it into service sections to be build by Dockerfile.
   `pull_policy` is a docker-compose-only field — `docker stack
   deploy` rejects it as "Additional property pull_policy is not
   allowed". Skip it under swarm mode (swarm always uses the locally
   resolved image via --resolve-image always at deploy time). #}
{% if DEPLOYMENT_MODE != 'swarm' %}
pull_policy: never
{% endif %}
build:
  context: .
  dockerfile: Dockerfile
{# pass Arguments here #}
