{% if DEPLOYMENT_MODE == 'swarm' %}
{{ "\n" }}
    deploy:
      {{ lookup('compose_replicas') }}
      update_config:
        parallelism: {{ service_update_parallelism | default(1) }}
        delay: {{ service_update_delay | default('10s') }}
      restart_policy:
        condition: any
      resources:
        limits:
          cpus: "{{ lookup('applications') | resource_filter(application_id, 'cpus', service_name | default(''), RESOURCE_CPUS) | string }}"
          memory: {{ lookup('applications') | resource_filter(application_id, 'mem_limit', service_name | default(''), RESOURCE_MEM_LIMIT) }}
          pids: {{ lookup('applications') | resource_filter(application_id, 'pids_limit', service_name | default(''), RESOURCE_PIDS_LIMIT) }}
        reservations:
          memory: {{ lookup('applications') | resource_filter(application_id, 'mem_reservation', service_name | default(''), RESOURCE_MEM_RESERVATION) }}
{% endif %}
