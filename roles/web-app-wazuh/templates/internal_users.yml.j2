---
# OpenSearch security plugin internal user database. Only the two service
# accounts our own containers actually authenticate as are declared here;
# real human users authenticate via the OIDC/SAML/LDAP backend configured in
# config.yml, never through this file. Hashes are computed in vars/main.yml
# from the plaintext credentials in meta/schema.yml (never generated here).
_meta:
  type: "internalusers"
  config_version: 2

admin:
  hash: "{{ WAZUH_INDEXER_ADMIN_HASH }}"
  reserved: true
  backend_roles:
    - "admin"
  description: "Bootstrap/service account used by securityadmin.sh, health checks, and manager/dashboard INDEXER_PASSWORD."

kibanaserver:
  hash: "{{ WAZUH_DASHBOARD_SERVICE_HASH }}"
  reserved: true
  description: "Service account wazuh.dashboard uses for its own backend calls to wazuh.indexer."
