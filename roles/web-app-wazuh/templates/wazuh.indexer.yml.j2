network.host: "0.0.0.0"
node.name: "{{ WAZUH_INDEXER_CONTAINER }}"
cluster.name: "wazuh-cluster"
path.data: /var/lib/wazuh-indexer
path.logs: /var/log/wazuh-indexer
discovery.type: single-node
compatibility.override_main_response_version: true
plugins.security.ssl.http.pemcert_filepath: {{ WAZUH_INDEXER_CERTS_DIR_CONTAINER }}/wazuh.indexer.pem
plugins.security.ssl.http.pemkey_filepath: {{ WAZUH_INDEXER_CERTS_DIR_CONTAINER }}/wazuh.indexer.key
plugins.security.ssl.http.pemtrustedcas_filepath: {{ WAZUH_INDEXER_CERTS_DIR_CONTAINER }}/root-ca.pem
plugins.security.ssl.transport.pemcert_filepath: {{ WAZUH_INDEXER_CERTS_DIR_CONTAINER }}/wazuh.indexer.pem
plugins.security.ssl.transport.pemkey_filepath: {{ WAZUH_INDEXER_CERTS_DIR_CONTAINER }}/wazuh.indexer.key
plugins.security.ssl.transport.pemtrustedcas_filepath: {{ WAZUH_INDEXER_CERTS_DIR_CONTAINER }}/root-ca.pem
plugins.security.ssl.http.enabled: true
plugins.security.ssl.transport.enforce_hostname_verification: false
plugins.security.ssl.transport.resolve_hostname: false
plugins.security.ssl.http.enabled_ciphers:
  - "TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256"
  - "TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384"
  - "TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256"
  - "TLS_ECDHE_ECDSA_WITH_AES_256_GCM_SHA384"
plugins.security.ssl.http.enabled_protocols:
  - "TLSv1.2"
plugins.security.authcz.admin_dn:
  - "CN=admin,OU=Wazuh,O=Wazuh,L=California,C=US"
plugins.security.check_snapshot_restore_write_privileges: true
plugins.security.enable_snapshot_restore_privilege: true
plugins.security.nodes_dn:
  - "CN={{ WAZUH_INDEXER_CONTAINER }},OU=Wazuh,O=Wazuh,L=California,C=US"
plugins.security.restapi.roles_enabled:
  - "all_access"
  - "security_rest_api_access"
plugins.security.system_indices.enabled: true
plugins.security.system_indices.indices: [".opendistro-alerting-config", ".opendistro-alerting-alert*", ".opendistro-anomaly-results*", ".opendistro-anomaly-detector*", ".opendistro-anomaly-checkpoints", ".opendistro-anomaly-detection-state", ".opendistro-reports-*", ".opendistro-notifications-*", ".opendistro-notebooks", ".opensearch-observability", ".opendistro-asynchronous-search-response*", ".replication-metadata-store"]
plugins.security.allow_default_init_securityindex: true
# OpenSearch Security's default auth cache TTL is 60 minutes: once a user is
# resolved, their backend_roles are cached by username and NOT re-derived
# from a fresh token until the cache expires - confirmed against a live
# deploy, where a test user's role change (group membership updated and
# re-verified correct in Keycloak, confirmed via a freshly-issued token
# with the correct groups claim) was still not reflected in the dashboard
# after a full logout/login, because the indexer kept serving the
# previously-cached, more-permissive role set. For a SIEM's RBAC, prompt
# revocation matters more than shaving auth latency on a single-node
# deployment at this scale, so caching is disabled outright rather than
# just shortened.
plugins.security.cache.ttl_minutes: 0
cluster.routing.allocation.disk.threshold_enabled: false
