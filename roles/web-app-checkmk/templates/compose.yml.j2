{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}
  {% set service_name = 'checkmk' %}
  {% set container_healthcheck = 'cmk/check_mk/login.py' %}
  {{ service_name }}:
    {{ lookup('container_image', application_id, 'checkmk') }}
    {{ lookup('compose_only', 'container_name', CHECKMK_NAME) }}
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_ports', ['checkmk', 'http', DOCKER_BIND_HOST], ['checkmk', 'agent', DOCKER_BIND_HOST]) | indent(4) }}
    {% include 'roles/sys-svc-container/templates/healthcheck/curl.yml.j2' %}

    {{ lookup('container_depends_on', application_id) | indent(4) }}
    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
    {{ lookup('container_networks') | indent(4) }}

{{ lookup('compose_volumes', application_id) }}

{{ lookup('compose_networks') }}
