{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}
  application:
{% set container_healthcheck = 'cmk/check_mk/login.py' %}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    image: "{{ CHECKMK_IMAGE }}:{{ CHECKMK_VERSION }}"
    container_name: "{{ CHECKMK_NAME }}"
    ports:
      - "{{ DOCKER_BIND_HOST }}:{{ lookup('config', application_id, 'services.checkmk.ports.local.http') }}:{{ container_port }}"
      - "{{ DOCKER_BIND_HOST }}:{{ lookup('config', application_id, 'services.checkmk.ports.local.agent') }}:{{ CHECKMK_AGENT_PORT }}"
    volumes:
      - "data:/omd/sites"
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
{{ lookup('container_depends_on', application_id) }}
{% include 'roles/sys-svc-container/templates/healthcheck/curl.yml.j2' %}

{{ lookup('applications') | compose_volumes(
    application_id,
    extra_volumes={'data': {'name': CHECKMK_VOLUME}}
) }}

{% include 'roles/sys-svc-compose/templates/networks.yml.j2' %}
