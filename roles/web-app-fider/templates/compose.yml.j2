{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

  fider:
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_image', application_id, 'fider') }}
    {{ lookup('compose_only', 'container_name', FIDER_CONTAINER) }}
    {{ lookup('container_ports', ['fider', 'http', DOCKER_BIND_HOST]) | indent(4) }}
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://127.0.0.1:{{ FIDER_CONTAINER_PORT }}/_health"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 30s

    {{ lookup('container_networks') | indent(4) }}
    {{ lookup('container_depends_on', application_id) | indent(4) }}

{{ lookup('compose_volumes', application_id,
) }}
{{ lookup('compose_networks') }}
