{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}
  {{ entity_name }}:
    image: "{{ REGISTRY_CACHE_IMAGE }}:{{ REGISTRY_CACHE_VERSION }}"
{% if DEPLOYMENT_MODE != 'swarm' %}
    {{ lookup('compose_only', 'container_name', REGISTRY_CACHE_CONTAINER) }}
{% endif %}
    environment:
      REGISTRY_PROXY_REMOTEURL: "{{ REGISTRY_CACHE_PROXY_REMOTE_URL }}"
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    ports:
      - "{{ REGISTRY_CACHE_PORT }}:5000"
    volumes:
      - "data:/var/lib/registry"
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}

{{ lookup('compose_volumes', application_id,
    extra_volumes={'data': {'name': REGISTRY_CACHE_DATA_VOLUME}}
) }}
{% include 'roles/sys-svc-compose/templates/networks.yml.j2' %}
