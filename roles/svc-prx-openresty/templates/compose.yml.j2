{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}
{# host-mode 80/443: stop-first avoids the rolling-update port-bind deadlock #}
{% set service_update_order = 'stop-first' %}
  openresty:
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('template', 'roles/sys-svc-container/templates/build.yml.j2') | indent(4) }}
      args:
        OPENRESTY_IMAGE:              "{{ OPENRESTY_IMAGE }}"
        OPENRESTY_VERSION:            "{{ OPENRESTY_VERSION }}"
        PROMETHEUS_ENABLED:           "{{ OPENRESTY_PROMETHEUS_ENABLED }}"
        LUA_PROMETHEUS_URL_MAIN:      "{{ OPENRESTY_LUA_PROMETHEUS_URL_MAIN }}"
        LUA_PROMETHEUS_URL_COUNTER:   "{{ OPENRESTY_LUA_PROMETHEUS_URL_COUNTER }}"
        LUA_PROMETHEUS_URL_KEYS:      "{{ OPENRESTY_LUA_PROMETHEUS_URL_KEYS }}"
    {{ lookup('compose_only', 'container_name', OPENRESTY_CONTAINER) }}
    {{ lookup('container_image', application_id, 'openresty', custom=True) }}
{% if DEPLOYMENT_MODE == 'swarm' %}
    ports:
      - target: 80
        published: 80
        protocol: tcp
        mode: host
      - target: 443
        published: 443
        protocol: tcp
        mode: host
    {{ lookup('container_networks') | indent(4) }}
{% else %}
    network_mode: "host"
{% endif %}
    {{ lookup('container_volumes', application_id, 'openresty') | indent(4) }}
    command: ["openresty", "-g", "daemon off;"]
    healthcheck:
      test: ["CMD", "openresty", "-t", "-q"]
      interval: 30s
      timeout: 5s
      retries: 3

{{ lookup('compose_volumes', application_id) }}
{{ lookup('compose_networks') }}
