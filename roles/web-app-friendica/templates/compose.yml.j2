{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}
  {{ FRIENDICA_SERVICE }}:
    image: "{{ FRIENDICA_IMAGE }}:{{ FRIENDICA_VERSION }}"
    container_name: "{{ FRIENDICA_CONTAINER }}"
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    volumes:
      - html:{{ FRIENDICA_APPLICATION_DIR }}
      - data:/var/www/data # I assume that this one is unnessecarry
{% if FRIENDICA_LDAP_ENABLED | bool %}
      - {{ FRIENDICA_LDAP_CONFIG_HOST }}:{{ FRIENDICA_LDAP_CONFIG_DOCKER }}:ro
{% endif %}
    ports:
      - "{{ DOCKER_BIND_HOST }}:{{ lookup('config', application_id, 'services.friendica.ports.local.http') }}:80"

{% include 'roles/sys-svc-container/templates/healthcheck/msmtp_curl.yml.j2' %}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
{{ lookup('container_depends_on', application_id) }}

{{ lookup('applications') | compose_volumes(
    application_id,
    extra_volumes={'data': {}, 'html': {}}
) }}
{% include 'roles/sys-svc-compose/templates/networks.yml.j2' %}
