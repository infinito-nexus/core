{% include 'roles/sys-svc-container/templates/env.j2' %}

BASEROW_PUBLIC_URL={{ BASEROW_PUBLIC_URL }}

SECRET_KEY={{ BASEROW_SECRET_KEY | dotenv_quote }}
BASEROW_SECRET_KEY={{ BASEROW_SECRET_KEY | dotenv_quote }}

PROXY_HEADER_SSO={{ BASEROW_SSO_PROXY_GATED | string | lower }}
PROXY_HEADER_SSO_ADMIN_GROUP={{ BASEROW_SSO_ADMIN_GROUP | dotenv_quote }}
PROXY_HEADER_SSO_FALLBACK_EMAIL_DOMAIN={{ BASEROW_SSO_FALLBACK_EMAIL_DOMAIN | dotenv_quote }}

{% set email = lookup('email', application_id) %}
{% if email.enabled | bool %}
EMAIL_SMTP={{ email.smtp | upper }}
EMAIL_SMTP_HOST={{ email.host }}
EMAIL_SMTP_PORT={{ email.port }}
EMAIL_SMTP_USER={{ email.username }}
EMAIL_SMTP_PASSWORD={{ email.password | dotenv_quote }}
EMAIL_SMTP_USE_TLS={{ email.tls | upper }}
{% endif %}

DATABASE_USER={{ BASEROW_DATABASE_USER }}
DATABASE_NAME={{ BASEROW_DATABASE_NAME }}
DATABASE_HOST={{ BASEROW_DATABASE_HOST }}
DATABASE_PORT={{ BASEROW_DATABASE_PORT }}
DATABASE_PASSWORD={{ BASEROW_DATABASE_PASSWORD | dotenv_quote }}
DATABASE_URL={{ BASEROW_DATABASE_URL }}

REDIS_HOST={{ BASEROW_REDIS_HOST }}
REDIS_PORT={{ BASEROW_REDIS_PORT }}
REDIS_URL={{ BASEROW_REDIS_URL }}

{% if lookup('objstore', application_id, 'enabled') | bool %}
AWS_ACCESS_KEY_ID={{ lookup('objstore', application_id, 'access_key') }}
AWS_SECRET_ACCESS_KEY={{ lookup('objstore', application_id, 'secret_key') | dotenv_quote }}
AWS_STORAGE_BUCKET_NAME={{ lookup('objstore', application_id, 'bucket') }}
AWS_S3_ENDPOINT_URL={{ lookup('objstore', application_id, 'url') }}
AWS_S3_REGION_NAME={{ lookup('objstore', application_id, 'region') }}
AWS_S3_CUSTOM_DOMAIN={{ lookup('objstore', application_id, 'public_bucket') }}
{% endif %}

DISABLE_EMBEDDED_PSQL=yes
DISABLE_EMBEDDED_REDIS=yes
SYNC_TEMPLATES_ON_STARTUP=false
BASEROW_TRIGGER_SYNC_TEMPLATES_AFTER_MIGRATION=false
BASEROW_DISABLE_PLUGIN_INSTALL_ON_STARTUP=yes
MIGRATE_ON_STARTUP=false
BASEROW_POSTGRES_STARTUP_CHECK_ATTEMPTS=30
