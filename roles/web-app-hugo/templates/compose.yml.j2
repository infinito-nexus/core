---
{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}
  {{ HUGO_SERVICE }}:
    {{ lookup('compose_only', 'container_name', HUGO_CONTAINER) }}
    {{ lookup('template', 'roles/sys-svc-container/templates/build.yml.j2') | indent(4) }}
      args:
        HUGO_BUILDER_IMAGE: "{{ HUGO_BUILDER_IMAGE }}"
        HUGO_BUILDER_VERSION: "{{ HUGO_BUILDER_VERSION }}"
        HUGO_NGINX_IMAGE: "{{ HUGO_NGINX_IMAGE }}"
        HUGO_NGINX_VERSION: "{{ HUGO_NGINX_VERSION }}"
        HUGO_BASE_URL: "{{ HUGO_BASE_URL }}"
        HUGO_ENVIRONMENT: "{{ HUGO_ENVIRONMENT }}"
        HUGO_MINIFY: "{{ HUGO_MINIFY | string | lower }}"
    {{ lookup('container_image', application_id, 'hugo', custom=True) }}
    {{ lookup('container_ports', ['hugo', 'http', DOCKER_BIND_HOST]) | indent(4) }}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
{% include 'roles/sys-svc-container/templates/healthcheck/wget.yml.j2' %}

{{ lookup('compose_volumes', application_id) }}

{{ lookup('compose_networks') }}
