location {{ webserver_websocket_location }} {
  proxy_set_header      Host              $host;
  proxy_set_header      X-Real-IP         $remote_addr;
  proxy_set_header      X-Forwarded-For   $proxy_add_x_forwarded_for;
  proxy_set_header      X-Forwarded-Proto $scheme;
  {{ lookup('proxy_pass', application_id, proxy_service_key | default(application_id | get_entity_name), 'http', tail='plain', local_port=websocket_port, internal_port=proxy_internal_port | default('')) }}

  {% include 'roles/sys-svc-proxy/templates/headers/upstream_strips.conf.j2' %}

  # Proxy buffering needs to be disabled for websockets.
  proxy_buffering      off;
  proxy_http_version   1.1;
  proxy_set_header     Upgrade            $http_upgrade;
  proxy_set_header     Connection         $connection_upgrade;
  tcp_nodelay          on;
}