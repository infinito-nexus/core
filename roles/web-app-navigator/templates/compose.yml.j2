{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}
  {{ NAVIGATOR_SERVICE }}:
    build:
      context:    {{ path_infinito_presentation_output.stdout }}
      dockerfile: {{ path_infinito_presentation_output.stdout }}/Dockerfile
    {{ lookup('container_image', application_id, 'navigator', image=NAVIGATOR_IMAGE) }}
    {{ lookup('compose_only', 'pull_policy', 'never') }}
    ports:
      - "{{ DOCKER_BIND_HOST }}:{{ lookup('config', application_id, 'services.navigator.ports.local.http') }}:{{ lookup('config', application_id, 'services.navigator.ports.internal.http') }}"
    {{ lookup('container_volumes', application_id, NAVIGATOR_SERVICE) | indent(4) }}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_networks') | indent(4) }}

{{ lookup('compose_volumes', application_id) }}

{{ lookup('compose_networks') }}
