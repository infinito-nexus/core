# ONLYOFFICE external PostgreSQL settings
DB_TYPE={{ lookup('database', application_id, 'type') }}
DB_HOST={{ lookup('database', application_id, 'host') }}
DB_PORT={{ lookup('database', application_id, 'port') }}
DB_NAME={{ lookup('database', application_id, 'name') }}
DB_USER={{ lookup('database', application_id, 'username') }}
DB_PWD={{ lookup('database', application_id, 'password') }}

# Redis
REDIS_SERVER_HOST={{ lookup('engine', 'redis', application_id, 'host') }}
REDIS_SERVER_PORT={{ lookup('engine', 'redis', application_id, 'port') }}
REDIS_SERVER_PASS={{ lookup('engine', 'redis', application_id, 'password') | dotenv_quote }}
# AMQP_URI=amqp://user:password@rabbitmq.example.internal:5672/onlyoffice

JWT_ENABLED=true
JWT_SECRET={{ ONLYOFFICE_JWT_SECRET }}
JWT_HEADER=Authorization
