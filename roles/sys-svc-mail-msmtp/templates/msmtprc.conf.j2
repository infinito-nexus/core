{% set email = lookup('email') %}
defaults
# EHLO/HELO identity — a valid FQDN. Strict servers (e.g. Stalwart) reject a
# bare container hostname on port 25 (rejectNonFqdn), so pin it to the domain.
domain              {{ DOMAIN_PRIMARY }}
logfile             ~/.msmtp.log
timeout             {{ email.timeout }}
syslog              {{ MODE_DEBUG | on_off }}
auth                {{ email.auth | on_off }}
tls_starttls        {{ email.start_tls | on_off }}
tls                 {{ email.tls | on_off }}
tls_trust_file      {{ sys_svc_mail_msmtp_ca_bundle }}
tls_host_override   {{ email.host }}
account             system_email_no_reply
host                {{ '127.0.0.1' if (email.external | bool and DOCKER_IN_CONTAINER | bool and (DEPLOYMENT_MODE == 'compose' or 'svc-swarm-node' in group_names)) else email.host }}
port                {{ email.port }}
from                {{ email['from'] }}
{% if (email.auth | bool) %}
user                {{ email.username }}
password            {{ email.password }}
{% endif %}
account default : system_email_no_reply
