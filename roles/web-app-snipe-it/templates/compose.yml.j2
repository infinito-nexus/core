{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

  {{ SNIPE_IT_SERVICE }}:
{% set container_port = 80 %}
    {{ lookup('container_image', application_id, 'snipe-it') }}
    {{ lookup('compose_only', 'container_name', SNIPE_IT_CONTAINER) }}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_volumes', application_id, SNIPE_IT_SERVICE) | indent(4) }}
    {{ lookup('container_ports', ['snipe-it', 'http', DOCKER_BIND_HOST]) | indent(4) }}
    {{ lookup('container_depends_on', application_id) | indent(4) }}
    {{ lookup('container_networks') | indent(4) }}
    healthcheck:
      test:
        - CMD
        - wget
        - -q
        - -O-
        - http://localhost/
      interval: 10s
      timeout: 5s
      retries: 12
      start_period: 60s

{{ lookup('compose_volumes', application_id) }}
{{ lookup('compose_networks') }}
