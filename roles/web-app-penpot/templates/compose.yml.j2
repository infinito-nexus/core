{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

  {{ PENPOT_FRONTEND_SERVICE }}:
{% set service_name = PENPOT_FRONTEND_SERVICE %}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_image', application_id, 'frontend') }}
    {{ lookup('compose_only', 'container_name', PENPOT_FRONTEND_CONTAINER) }}
    {{ lookup('container_ports', ['penpot', 'http', DOCKER_BIND_HOST]) | indent(4) }}
    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
{% set container_port = PENPOT_FRONTEND_INTERNAL_PORT %}
{% include 'roles/sys-svc-container/templates/healthcheck/curl.yml.j2' %}
    {{ lookup('container_networks') | indent(4) }}
    {{ lookup('container_depends_on', application_id, extra={
  PENPOT_BACKEND_SERVICE: {'condition': 'service_started'},
  PENPOT_EXPORTER_SERVICE: {'condition': 'service_started'},
}) | indent(4) }}

  {{ PENPOT_BACKEND_SERVICE }}:
{% set service_name = PENPOT_BACKEND_SERVICE %}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_image', application_id, 'backend') }}
    {{ lookup('compose_only', 'container_name', PENPOT_BACKEND_CONTAINER) }}
{% if (TLS_MODE | lower) == 'self_signed' %}
    # Self-signed TLS only: the JVM truststore doesn't trust the internal CA
    # (with-ca-trust.sh covers OS/NSS/env, not Java cacerts; backend runs uid 1001),
    # so import it before start; otherwise OIDC calls to Keycloak fail PKIX.
    command:
      - /bin/bash
      - -c
      - |
        cp /opt/jdk/lib/security/cacerts /tmp/cacerts 2>/dev/null || true
        /opt/jdk/bin/keytool -importcert -keystore /tmp/cacerts -storepass changeit -noprompt -alias infinito-ca -file /tmp/infinito/ca/root-ca.crt >/dev/null 2>&1 || true
        export JAVA_TOOL_OPTIONS="-Djavax.net.ssl.trustStore=/tmp/cacerts -Djavax.net.ssl.trustStorePassword=changeit"
        exec /bin/bash run.sh
{% endif %}
    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
    {{ lookup('container_networks') | indent(4) }}
    {{ lookup('container_depends_on', application_id) | indent(4) }}

  {{ PENPOT_EXPORTER_SERVICE }}:
{% set service_name = PENPOT_EXPORTER_SERVICE %}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_image', application_id, 'exporter') }}
    {{ lookup('compose_only', 'container_name', PENPOT_EXPORTER_CONTAINER) }}
    {{ lookup('container_networks') | indent(4) }}
    {{ lookup('container_depends_on', application_id) | indent(4) }}

{{ lookup('compose_volumes', application_id) }}
{{ lookup('compose_networks') }}
