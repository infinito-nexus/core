{# Penpot stack: frontend + backend + exporter, with shared postgres and a #}
{# role-local redis sidecar (both emitted by the sys-svc-compose base). #}
{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

  {{ PENPOT_FRONTEND_SERVICE }}:
{% set service_name = PENPOT_FRONTEND_SERVICE %}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    image: "{{ PENPOT_FRONTEND_IMAGE }}:{{ PENPOT_VERSION }}"
    container_name: {{ PENPOT_FRONTEND_CONTAINER }}
    ports:
      - "{{ DOCKER_BIND_HOST }}:{{ lookup('config', application_id, 'services.penpot.ports.local.http') }}:{{ PENPOT_FRONTEND_INTERNAL_PORT }}"
    volumes:
      - "assets:{{ PENPOT_ASSETS_FS_DIRECTORY }}"
{% set container_port = PENPOT_FRONTEND_INTERNAL_PORT %}
{% include 'roles/sys-svc-container/templates/healthcheck/curl.yml.j2' %}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
{{ lookup('container_depends_on', application_id, extra={
  PENPOT_BACKEND_SERVICE: {'condition': 'service_started'},
  PENPOT_EXPORTER_SERVICE: {'condition': 'service_started'},
}) }}

  {{ PENPOT_BACKEND_SERVICE }}:
{% set service_name = PENPOT_BACKEND_SERVICE %}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    image: "{{ PENPOT_BACKEND_IMAGE }}:{{ PENPOT_VERSION }}"
    container_name: {{ PENPOT_BACKEND_CONTAINER }}
    volumes:
      - "assets:{{ PENPOT_ASSETS_FS_DIRECTORY }}"
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
{{ lookup('container_depends_on', application_id) }}

  {{ PENPOT_EXPORTER_SERVICE }}:
{% set service_name = PENPOT_EXPORTER_SERVICE %}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    image: "{{ PENPOT_EXPORTER_IMAGE }}:{{ PENPOT_VERSION }}"
    container_name: {{ PENPOT_EXPORTER_CONTAINER }}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
{{ lookup('container_depends_on', application_id) }}

{{ lookup('applications') | compose_volumes(
    application_id,
    extra_volumes={'assets': {'name': PENPOT_ASSETS_VOLUME}}
) }}
{% include 'roles/sys-svc-compose/templates/networks.yml.j2' %}
