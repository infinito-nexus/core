http_address            =   "0.0.0.0:{{ lookup('config', 'web-app-keycloak', 'services.sso_proxy.ports.internal.http') }}"
cookie_secret           =   "{{ lookup('config', sso_proxy_application_id, 'credentials.sso_proxy_cookie_secret') }}"
cookie_secure           =   "{{ lookup('tls', sso_proxy_application_id, 'enabled') | string | lower }}"                                                                            # True is necessary to force the cookie set via https
upstreams               =   "http://{{ lookup('sso', sso_proxy_application_id, 'oauth2_origin_host') }}:{{ lookup('sso', sso_proxy_application_id, 'oauth2_origin_port') }}"  # nocheck: literal-protocol-lookup  Internal docker upstream is plaintext by design.
{% set _tor_node = lookup('config', 'svc-net-tor', 'services.tor.node', '') %}
{% set _app_domains = lookup('domains', sso_proxy_application_id) %}
{% set _has_onion = _tor_node != '' and (_app_domains | select('search', _tor_node) | list | length > 0) %}
{% set _clearnet_domains = _app_domains | reject('search', '\.onion$') | list %}
{% set _has_clearnet = _clearnet_domains | length > 0 %}
{% if _has_clearnet %}
cookie_domains          =   ["{{ _clearnet_domains | common_dns_suffix }}", "{{ lookup('domain', 'web-app-keycloak') }}"]
{% endif %}
whitelist_domains       =   [{% if _has_clearnet %}".{{ DOMAIN_PRIMARY }}"{% endif %}{% if _has_clearnet and _has_onion %}, {% endif %}{% if _has_onion %}".{{ _tor_node }}"{% endif %}]

# keycloak provider
client_secret           =   "{{ OIDC.CLIENT.SECRET }}"
client_id               =   "{{ OIDC.CLIENT.ID }}"
redirect_url            =   "{{ lookup('tls', sso_proxy_application_id, 'protocols.web') }}://{{ lookup('domain', sso_proxy_application_id) }}/oauth2/callback"
oidc_issuer_url         =   "{{ OIDC.CLIENT.ISSUER_URL }}"
provider                =   "oidc"
provider_display_name   =   "{{ OIDC.BUTTON_TEXT }}"
{% if (TLS_MODE | lower) == 'self_signed' %}
provider_ca_files       =   ["/tmp/infinito/ca/root-ca.crt"]
{% endif %}

{% set allowed_groups_raw = lookup('sso', sso_proxy_application_id, 'oauth2_allowed_groups') %}
{% if allowed_groups_raw %}
{# role based restrictions #}
scope                   =   "openid email profile {{ RBAC.GROUP.CLAIM }}"
oidc_groups_claim       =   "{{ RBAC.GROUP.CLAIM }}"
{# oauth2-proxy compares allowed_groups against the JWT groups claim by literal
   string equality. Keycloak's group-membership-mapper emits paths with a
   leading slash when full.path=true (the realm-import default for the shared
   `groups` client-scope). The `rbac_group_path` lookup, by historical contract,
   returns the path without the leading slash — see
   tests/unit/plugins/lookup/test_rbac_group_path.py. Normalise here to exactly
   one leading slash so oauth2-proxy's literal match lines up with what the
   token actually carries. #}
allowed_groups          =   {{ allowed_groups_raw | map('regex_replace', '^/*', '/') | list | to_json }}
email_domains           =   ["*"]
{% else %}
email_domains           =   "{{ DOMAIN_PRIMARY }}"
{% endif %}

session_store_type       = "redis"
redis_connection_url     = "redis://redis:6379"

# Identity headers — make oauth2-proxy export the authenticated
# user's identity in the auth_request response so the gated upstream
# (e.g. the Bluesky login-broker) can read X-Forwarded-User /
# X-Forwarded-Email through the nginx auth_request_set bridge in
# `following_directives.conf.j2`.
set_xauthrequest         = true
pass_user_headers        = true
pass_access_token        = true
