{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}
  {% set service_name = entity_name %}
  {{ service_name }}:
    image: "{{ REGISTRY_IMAGE }}:{{ REGISTRY_VERSION }}"  # nocheck: container-image-lookup
    {{ lookup('compose_only', 'container_name', REGISTRY_CONTAINER) }}
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {% if DEPLOYMENT_MODE == 'swarm' %}
    environment:
      REGISTRY_HTTP_ADDR: "{{ REGISTRY_BIND_IP }}:{{ REGISTRY_PORT }}"
    {% else %}
    {{ lookup('container_ports', ['docker', 'registry']) | indent(4) }}
    {% endif %}
    {{ lookup('container_volumes', application_id, entity_name) | indent(4) }}
    {% if DEPLOYMENT_MODE == 'swarm' %}
    networks: # nocheck: networks-literal
      hostnet: {}
    {% else %}
    {{ lookup('container_networks') | indent(4) }}
    {% endif %}

{{ lookup('compose_volumes', application_id) }}
{% if DEPLOYMENT_MODE == 'swarm' %}
networks: # nocheck: networks-literal
  hostnet:
    external: true
    name: host
{% else %}
{{ lookup('compose_networks') }}
{% endif %}
