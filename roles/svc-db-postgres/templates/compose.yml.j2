{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

  postgres:
    {{ lookup('compose_only', 'container_name', POSTGRES_CONTAINER) }}
    image:            "{{ POSTGRES_CUSTOM_IMAGE }}"
    {{ lookup('template', 'roles/sys-svc-container/templates/build.yml.j2') | indent(4) }}
    command:
      - "postgres"
      - "-c"
      - "max_connections={{ POSTGRES_MAX_CONNECTIONS }}"
      - "-c"
      - "superuser_reserved_connections={{ POSTGRES_SUPERUSER_RESERVED_CONNECTIONS }}"
      - "-c"
      - "shared_buffers={{ POSTGRES_SHARED_BUFFERS }}"
      - "-c"
      - "work_mem={{ POSTGRES_WORK_MEM }}"
      - "-c"
      - "maintenance_work_mem={{ POSTGRES_MAINTENANCE_WORK_MEM }}"

{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
{% if POSTGRES_EXPOSE_LOCAL %}
    ports: 
      - "{{ DOCKER_BIND_HOST }}:{{ POSTGRES_PORT }}:5432"
{% endif %}
    {{ lookup('container_volumes', application_id, 'postgres') | indent(4) }}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}

{{ lookup('compose_volumes', application_id) }}
{% include 'roles/sys-svc-compose/templates/networks.yml.j2' %}
