FROM {{ POSTGRES_IMAGE }}:{{ POSTGRES_VERSION }}

{% if POSTGRES_LIBRARIES | length > 0 %}
RUN rm -rf /var/lib/apt/lists/* \
 && apt-get update \
 && apt-get install -y --no-install-recommends \
      build-essential \
      git \
      postgresql-server-dev-{{ POSTGRES_VERSION_MAJOR | default('all', true) }} \
{% for lib in POSTGRES_LIBRARIES %}
{# nocheck: repository-declared — extension source, not the role's primary repo #}
 && git clone {{ lib.git_source }} /tmp/{{ lib.name }} \
 && cd /tmp/{{ lib.name }} \
 && make \
 && make install \
 && rm -rf /tmp/{{ lib.name }} \
{% endfor %}
 && apt-get purge -y --auto-remove git build-essential \
 && rm -rf /var/lib/apt/lists/*
{% endif %}

COPY <<'BOOT_ENTRYPOINT_EOF' /usr/local/bin/boot-entrypoint.sh
{{ lookup('file', lookup('path_absolute', 'roles/svc-db-postgres/files/boot-entrypoint.sh')) }}
BOOT_ENTRYPOINT_EOF
RUN chmod +x /usr/local/bin/boot-entrypoint.sh

ENTRYPOINT ["boot-entrypoint.sh"]
CMD ["postgres"]

HEALTHCHECK --interval=10s \
            --timeout=5s \
            --start-period=15m \
            --retries=5 \
  CMD pg_isready -U postgres || exit 1
