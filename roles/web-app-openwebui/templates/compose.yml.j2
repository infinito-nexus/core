{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}
  {% set service_name = 'openwebui' %}
  {{ service_name }}:
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_image', application_id, 'openwebui') }}
    {{ lookup('compose_only', 'container_name', OPENWEBUI_CONTAINER) }}
    {{ lookup('container_ports', ['openwebui', 'http', DOCKER_BIND_HOST]) | indent(4) }}
    {{ lookup('container_volumes', application_id, 'openwebui') | indent(4) }}
    {{ lookup('container_networks') | indent(4) }}

{{ lookup('compose_networks') }}

{{ lookup('compose_volumes', application_id) }}
