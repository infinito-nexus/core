{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

  gitlab:
    {{ lookup('container_image', application_id, 'gitlab', custom=True) }}
    hostname: '{{ GITLAB_HOSTNAME }}'
    {{ lookup('compose_only', 'container_name', GITLAB_CONTAINER) }}
    {{ lookup('compose_only', 'pull_policy', 'never') }}
    build:
      context: .
      dockerfile: Dockerfile
      args:
        GITLAB_IMAGE: "{{ GITLAB_IMAGE }}"
        GITLAB_VERSION: "{{ GITLAB_VERSION }}"
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_ports',
              ['gitlab', 'http', DOCKER_BIND_HOST],
              ['gitlab', 'ssh']) | indent(4) }}
    {{ lookup('container_volumes', application_id, 'gitlab') | indent(4) }}
    shm_size: '256m'
    {{ lookup('container_depends_on', application_id) | indent(4) }}
    {{ lookup('container_networks') | indent(4) }}

{{ lookup('compose_volumes', application_id) }}
{{ lookup('compose_networks') }}
