{% include 'roles/sys-svc-container/templates/env.j2' %}

JOOMLA_SITE_NAME={{ JOOMLA_SITE_NAME }}
JOOMLA_ADMIN_USER={{ JOOMLA_USER }}
JOOMLA_ADMIN_USERNAME={{ JOOMLA_USER_NAME }}
JOOMLA_ADMIN_PASSWORD={{ JOOMLA_USER_PASSWORD | dotenv_quote }}
JOOMLA_ADMIN_EMAIL={{ JOOMLA_USER_EMAIL }}

{% if lookup('database', application_id, 'type') == 'mariadb' %}
JOOMLA_DB_HOST={{ lookup('database', application_id, 'host') }}:{{ lookup('database', application_id, 'port') }}
JOOMLA_DB_USER={{ lookup('database', application_id, 'username') }}
JOOMLA_DB_PASSWORD={{ lookup('database', application_id, 'password') | dotenv_quote }}
JOOMLA_DB_NAME={{ lookup('database', application_id, 'name') }}
JOOMLA_DB_TYPE={{ JOOMLA_DB_CONNECTOR }}
{% endif %}

{% if lookup('config', application_id, 'addons.plg_system_keycloak.enabled') | bool %}
{% set JOOMLA_OIDC = lookup('config', application_id, 'addons.plg_system_keycloak.config') %}
JOOMLA_OIDC_ISSUER_URL={{ JOOMLA_OIDC.issuer_url }}
JOOMLA_OIDC_CLIENT_ID={{ JOOMLA_OIDC.client_id }}
JOOMLA_OIDC_CLIENT_SECRET={{ JOOMLA_OIDC.client_secret | dotenv_quote }}
JOOMLA_OIDC_REDIRECT_URI={{ JOOMLA_OIDC.redirect_uri }}
JOOMLA_OIDC_END_SESSION_URL={{ JOOMLA_OIDC.end_session_url }}
JOOMLA_OIDC_FALLBACK_ENABLED={{ JOOMLA_OIDC.fallback_enabled }}
JOOMLA_OIDC_GROUP_ADMIN={{ JOOMLA_OIDC.group_admin }}
JOOMLA_OIDC_GROUP_EDITOR={{ JOOMLA_OIDC.group_editor }}
JOOMLA_OIDC_GROUP_USER={{ JOOMLA_OIDC.group_user }}
{% endif %}
