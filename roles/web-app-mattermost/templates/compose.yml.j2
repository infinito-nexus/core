{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

  application:
{% set service_name = 'application' %}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    image: "{{ MATTERMOST_IMAGE }}:{{ MATTERMOST_VERSION }}"
    {{ lookup('compose_only', 'container_name', MATTERMOST_CONTAINER) }}
    ports:
      - "{{ DOCKER_BIND_HOST }}:{{ lookup('config', application_id, 'services.mattermost.ports.local.http') }}:{{ container_port }}"
    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
    healthcheck:
      test: ["CMD", "/mattermost/bin/mmctl", "--local", "system", "status"]
      interval: 1m
      timeout: 10s
      retries: 3
      start_period: 30s

{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
{{ lookup('container_depends_on', application_id) }}

{{ lookup('compose_volumes', application_id) }}
{% include 'roles/sys-svc-compose/templates/networks.yml.j2' %}
