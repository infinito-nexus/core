{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

  {% set service_name = 'mattermost' %}
  {{ service_name }}:
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_image', application_id, 'mattermost') }}
    {{ lookup('compose_only', 'container_name', MATTERMOST_CONTAINER) }}
    {{ lookup('container_ports', ['mattermost', 'http', DOCKER_BIND_HOST]) | indent(4) }}
    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
    healthcheck:
      test: ["CMD", "/mattermost/bin/mmctl", "--local", "system", "status"]
      interval: 1m
      timeout: 10s
      retries: 3
      start_period: 30s

    {{ lookup('container_networks') | indent(4) }}
    {{ lookup('container_depends_on', application_id) | indent(4) }}

{{ lookup('compose_volumes', application_id) }}
{{ lookup('compose_networks') }}
