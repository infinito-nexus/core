{% include 'roles/sys-svc-container/templates/env.j2' %}

MUSIC_DIRECTORY_PATH={{FUNKWHALE_MUSIC_DIR}}

FUNKWHALE_WEB_WORKERS=4
FUNKWHALE_HOSTNAME={{ lookup('domain',application_id) }}
FUNKWHALE_PROTOCOL={{ lookup('tls', application_id, 'protocols.web') }}

LOGLEVEL={% if MODE_DEBUG | bool %}debug{% else %}error{% endif %}

DJANGO_LOGLEVEL={% if MODE_DEBUG | bool %}debug{% else %}error{% endif %}

{% set email = lookup('email', application_id) %}
{% if email.enabled | bool %}
EMAIL_CONFIG=smtp+tls://{{ lookup('users', 'no-reply').username }}:{{ email.password }}@{{ email.host }}:{{ email.port }}

DEFAULT_FROM_EMAIL={{ email['from'] }}
{% endif %}

REVERSE_PROXY_TYPE=nginx

FUNKWHALE_API_PORT={{ FUNKWHALE_DOCKER_API_PORT }}

CELERYD_CONCURRENCY={{FUNKWHALE_CELERYD_CONCURRENCY}}

MEDIA_ROOT={{ FUNKWHALE_MEDIA_DIR }}

{% if lookup('objstore', application_id, 'enabled') | bool %}
AWS_ACCESS_KEY_ID={{ lookup('objstore', application_id, 'access_key') }}
AWS_SECRET_ACCESS_KEY={{ lookup('objstore', application_id, 'secret_key') }}
AWS_STORAGE_BUCKET_NAME={{ lookup('objstore', application_id, 'bucket') }}
AWS_S3_ENDPOINT_URL={{ lookup('objstore', application_id, 'url') }}
AWS_S3_REGION_NAME={{ lookup('objstore', application_id, 'region') }}
PROXY_MEDIA=true
{% endif %}

STATIC_ROOT={{FUNKWHALE_STATIC_DIR}}

DJANGO_SETTINGS_MODULE=config.settings.production

DJANGO_SECRET_KEY={{ lookup('config', application_id, 'credentials.django_secret')}}

{% if lookup('config',application_id, 'services.ldap.enabled', False) %}
LDAP_ENABLED=True
LDAP_SERVER_URI={{ LDAP.SERVER.URI }}
LDAP_BIND_DN={{ LDAP.DN.ADMINISTRATOR.DATA }}
LDAP_BIND_PASSWORD={{ LDAP.BIND_CREDENTIAL | dotenv_quote }}
LDAP_SEARCH_FILTER={{ LDAP.FILTERS.USERS.LOGIN | replace('%' ~ LDAP.USER.ATTRIBUTES.ID, '{0}') }}
LDAP_START_TLS=False
LDAP_ROOT_DN={{ LDAP.DN.ROOT }}
LDAP_USER_ATTR_MAP='{"username":"uid","first_name":"givenName","last_name":"sn","email":"mail"}'
{% endif %}

FUNKWHALE_FRONTEND_PATH=/srv/funkwhale/front/dist

DATABASE_URL={{ lookup('database', application_id, 'url_full') }}
WEB_CONCURRENCY={{ POSTGRES_ALLOWED_AVG_CONNECTIONS }}
WORKER_THREADS={{ POSTGRES_ALLOWED_AVG_CONNECTIONS | int // 2 }}
