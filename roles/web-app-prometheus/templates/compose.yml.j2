{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

  {% set service_name = 'prometheus' %}
  {{ service_name }}:
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_image', application_id, 'prometheus') }}
    {{ lookup('compose_only', 'container_name', PROMETHEUS_CONTAINER) }}
    {{ lookup('container_ports', ['prometheus', 'http', DOCKER_BIND_HOST]) | indent(4) }}
    extra_hosts:
      - "host.docker.internal:host-gateway"
    command:
      - "--config.file={{ PROMETHEUS_CONFIG_DOCKER }}"
      - "--storage.tsdb.path=/prometheus"
      - "--web.enable-lifecycle"
    {{ lookup('container_volumes', application_id, 'prometheus') | indent(4) }}

    {{ lookup('container_networks') | indent(4) }}
      {% for metrics_app_id in lookup('native_metrics_apps') %}
      {{ metrics_app_id | get_entity_name }}:
      {% endfor %}
  {% set service_name = 'blackbox-exporter' %}
  {{ service_name }}:
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_image', application_id, 'blackbox-exporter') }}
    {{ lookup('compose_only', 'container_name', BLACKBOX_CONTAINER) }}
    command:
      - "--config.file={{ BLACKBOX_CONFIG_DOCKER }}"
    {{ lookup('container_volumes', application_id, 'blackbox-exporter') | indent(4) }}

  {% set service_name = 'alertmanager' %}
  {{ service_name }}:
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_image', application_id, 'alertmanager') }}
    {{ lookup('compose_only', 'container_name', ALERTMANAGER_CONTAINER) }}
    command:
      - "--config.file={{ ALERTMANAGER_CONFIG_DOCKER }}"
      - "--storage.path=/alertmanager"
    {{ lookup('container_volumes', application_id, 'alertmanager') | indent(4) }}

  {% set service_name = 'cadvisor' %}
  {{ service_name }}:
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_image', application_id, 'cadvisor') }}
    {{ lookup('compose_only', 'container_name', CADVISOR_CONTAINER) }}
    {% if DEPLOYMENT_MODE == 'compose' %}
    privileged: true
    devices:
      - /dev/kmsg
    {% endif %}
    {{ lookup('container_volumes', application_id, 'cadvisor') | indent(4) }}

  {% set service_name = 'node-exporter' %}
  {{ service_name }}:
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_image', application_id, 'node-exporter') }}
    {{ lookup('compose_only', 'container_name', NODE_EXPORTER_CONTAINER) }}
    {% if DEPLOYMENT_MODE == 'compose' %}
    # nocheck: network-mode-host-without-swarm-gate
    network_mode: host
    pid: host
    {% endif %}
    {{ lookup('container_volumes', application_id, 'node-exporter') | indent(4) }}
    command:
      - "--path.procfs=/host/proc"
      - "--path.rootfs=/rootfs"
      - "--path.sysfs=/host/sys"
      - "--collector.filesystem.mount-points-exclude=^/(sys|proc|dev|host|etc)($$|/)"

{{ lookup('compose_volumes', application_id) }}
{{ lookup('compose_networks') }}
  {% for metrics_app_id in lookup('native_metrics_apps') %}
  {% set service_name = metrics_app_id | get_entity_name %}
  {{ service_name }}:
    external: true
  {% endfor %}
