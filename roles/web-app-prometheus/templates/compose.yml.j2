{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

  application:
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    image: "{{ PROMETHEUS_IMAGE }}:{{ PROMETHEUS_VERSION }}"
    {{ lookup('compose_only', 'container_name', PROMETHEUS_CONTAINER) }}
    ports:
      - "{{ DOCKER_BIND_HOST }}:{{ lookup('config', application_id, 'services.prometheus.ports.local.http') }}:9090"
    extra_hosts:
      - "host.docker.internal:host-gateway"
    command:
      - "--config.file={{ PROMETHEUS_CONFIG_DOCKER }}"
      - "--storage.tsdb.path=/prometheus"
      - "--web.enable-lifecycle"
    {{ lookup('container_volumes', application_id, 'application') | indent(4) }}

{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
{% for metrics_app_id in lookup('native_metrics_apps') %}
      {{ metrics_app_id | get_entity_name }}:
{% endfor %}
  blackbox-exporter:
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    image: "{{ BLACKBOX_IMAGE }}:{{ BLACKBOX_VERSION }}"
    {{ lookup('compose_only', 'container_name', BLACKBOX_CONTAINER) }}
    command:
      - "--config.file={{ BLACKBOX_CONFIG_DOCKER }}"
    {{ lookup('container_volumes', application_id, 'blackbox-exporter') | indent(4) }}

  alertmanager:
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    image: "{{ ALERTMANAGER_IMAGE }}:{{ ALERTMANAGER_VERSION }}"
    {{ lookup('compose_only', 'container_name', ALERTMANAGER_CONTAINER) }}
    command:
      - "--config.file={{ ALERTMANAGER_CONFIG_DOCKER }}"
      - "--storage.path=/alertmanager"
    {{ lookup('container_volumes', application_id, 'alertmanager') | indent(4) }}

  cadvisor:
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    image: "{{ CADVISOR_IMAGE }}:{{ CADVISOR_VERSION }}"
    {{ lookup('compose_only', 'container_name', CADVISOR_CONTAINER) }}
    privileged: true
    devices:
      - /dev/kmsg
    {{ lookup('container_volumes', application_id, 'cadvisor') | indent(4) }}

  node-exporter:
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    image: "{{ NODE_EXPORTER_IMAGE }}:{{ NODE_EXPORTER_VERSION }}"
    {{ lookup('compose_only', 'container_name', NODE_EXPORTER_CONTAINER) }}
    # network_mode: host is required so node-exporter sees the host's real
    # network interfaces, disk mounts, and process table. Without it, interface
    # bandwidth metrics reflect the container's virtual stack only and are
    # meaningless. pid: host is required to collect accurate per-process CPU
    # and memory metrics. Security trade-off: removes Docker network isolation
    # for this read-only monitoring container, which is the standard accepted
    # practice for node-exporter. Port note: node-exporter binds on host port
    # 9100; ensure nothing else on the host uses port 9100.
    # nocheck: network-mode-host-without-swarm-gate
    network_mode: host
    pid: host
    {{ lookup('container_volumes', application_id, 'node-exporter') | indent(4) }}
    command:
      - "--path.procfs=/host/proc"
      - "--path.rootfs=/rootfs"
      - "--path.sysfs=/host/sys"
      - "--collector.filesystem.mount-points-exclude=^/(sys|proc|dev|host|etc)($$|/)"

{{ lookup('compose_volumes', application_id) }}
{% include 'roles/sys-svc-compose/templates/networks.yml.j2' %}
{% for metrics_app_id in lookup('native_metrics_apps') %}
  {{ metrics_app_id | get_entity_name }}:
    external: true
{% endfor %}
