{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

  gitea:
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_image', application_id, 'gitea') }}
    {{ lookup('compose_only', 'container_name', GITEA_CONTAINER) }}
    ports:
      - "{{ DOCKER_BIND_HOST }}:{{ lookup('config', application_id, 'services.gitea.ports.local.http') }}:{{ container_port }}"
      - "{{lookup('config', application_id, 'services.gitea.ports.public.ssh')}}:{{ lookup('config', application_id, 'services.gitea.ports.internal.ssh') }}"
    {{ lookup('container_volumes', application_id, 'gitea') | indent(4) }}
{% include 'roles/sys-svc-container/templates/healthcheck/curl.yml.j2' %}
    {{ lookup('container_networks') | indent(4) }}
{{ lookup('container_depends_on', application_id) }}

{{ lookup('compose_volumes', application_id) }}
{{ lookup('compose_networks') }}
