{% set service_name = 'synapse' %}
  {{ service_name }}:
{% include 'roles/sys-svc-container/templates/deploy.yml.j2' %}
{% set container_port = MATRIX_SYNAPSE_CONTAINER_PORT %}
    image: "{{ MATRIX_SYNAPSE_IMAGE }}:{{ MATRIX_SYNAPSE_VERSION }}"
    {{ lookup('compose_only', 'container_name', MATRIX_SYNAPSE_NAME) }}
    {{ lookup('compose_restart') }}
    logging:
      driver: journald
{% set _synapse_extra_mounts = [] %}
{% for item in MATRIX_BRIDGES %}
{%   set _ = _synapse_extra_mounts.append(lookup('container', application_id, 'directories.instance') ~ 'mautrix/' ~ item.bridge_name ~ '/registration.yaml:' ~ MATRIX_REGISTRATION_FILE_FOLDER ~ item.bridge_name ~ '.registration.yaml:ro') %}
{% endfor %}
    {{ lookup('container_volumes', application_id, service_name, extra_volumes=_synapse_extra_mounts) | indent(4) }}
    environment:
      - SYNAPSE_SERVER_NAME={{ MATRIX_SYNAPSE_DOMAIN }}
      - SYNAPSE_REPORT_STATS=no
    ports:
      - "{{ DOCKER_BIND_HOST }}:{{lookup('config', 'web-app-matrix', 'services.synapse.ports.local.http')}}:{{ container_port }}"
{% include 'roles/sys-svc-container/templates/healthcheck/curl.yml.j2' %}
{% if MATRIX_BRIDGES | length > 0 %}
{% set deps = {} %}
{% for item in MATRIX_BRIDGES %}{% set _ = deps.__setitem__('mautrix-' ~ item.bridge_name, 'service_healthy') %}{% endfor %}
    {{ lookup('depends_on', deps) }}
{% endif %}
{{ lookup('container_depends_on', application_id) }}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
{% set service_name = 'element' %}
  {{ service_name }}:
{% include 'roles/sys-svc-container/templates/deploy.yml.j2' %}
{% set container_port = 80 %}
    image: "{{ MATRIX_ELEMENT_IMAGE }}:{{ MATRIX_ELEMENT_VERSION }}"
    {{ lookup('compose_only', 'container_name', MATRIX_ELEMENT_NAME) }}
    {{ lookup('compose_restart') }}
    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
    ports:
      - "{{ DOCKER_BIND_HOST }}:{{ MATRIX_ELEMENT_PORT }}:{{ container_port }}"
{% include 'roles/sys-svc-container/templates/healthcheck/wget.yml.j2' %}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}

{% for item in MATRIX_BRIDGES %}
{% set service_name = 'mautrix-' ~ item.bridge_name %}
  {{ service_name }}:
{% include 'roles/sys-svc-container/templates/deploy.yml.j2' %}
    {{ lookup('compose_only', 'container_name', 'matrix-' ~ item.bridge_name) }}
    image: dock.mau.dev/mautrix/{{ item.bridge_name }}:latest
    {{ lookup('compose_restart') }}
    volumes: # nocheck: compose-inline-mount-section
      - ./mautrix/{{ item.bridge_name }}:/data
    healthcheck:
      test: ["CMD-SHELL", "test -f {{ MATRIX_REGISTRATION_FILE_FOLDER }}registration.yaml || exit 1"]
      interval: 1m
      timeout: 10s
      retries: 3
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}
{% endfor %}
{% if lookup('config', application_id, 'services.matrix.plugins.chatgpt') | bool %}
{% set service_name = 'matrix-chatgpt-bot' %}
  {{ service_name }}:
{% include 'roles/sys-svc-container/templates/deploy.yml.j2' %}
    {{ lookup('compose_restart') }}
    {{ lookup('compose_only', 'container_name', "matrix-chatgpt") }}
    image: "{{ MATRIX_CHATGPT_BOT_IMAGE }}:{{ MATRIX_CHATGPT_BOT_VERSION }}"
    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
    environment:
      OPENAI_API_KEY: "{{ lookup('config', application_id, 'credentials.chatgpt_bridge_openai_api_key')}}"
      CHATGPT_CONTEXT: 'thread'
      CHATGPT_API_MODEL: 'gpt-3.5-turbo'
      CHATGPT_REVERSE_PROXY: 'https://api.openai.com/v1/chat/completions'
      CHATGPT_MAX_PROMPT_TOKENS: '3000'
      KEYV_BACKEND: 'file'
      KEYV_URL: ''
      KEYV_BOT_ENCRYPTION: 'false'
      KEYV_BOT_STORAGE: 'true'
      MATRIX_HOMESERVER_URL: '{{ MATRIX_SYNAPSE_URL }}'
      MATRIX_BOT_USERNAME: '@chatgptbot:{{ MATRIX_SERVER_NAME }}'
      MATRIX_ACCESS_TOKEN: "{{ lookup('config', application_id, 'credentials.chatgpt_bridge_access_token', '') }}"
      MATRIX_BOT_PASSWORD: "{{ lookup('config', application_id, 'credentials.chatgpt_bridge_user_password') }}"
      MATRIX_DEFAULT_PREFIX: '!chatgpt'
      MATRIX_DEFAULT_PREFIX_REPLY: 'false'
      MATRIX_WHITELIST: ':{{ MATRIX_SERVER_NAME }}'
      MATRIX_AUTOJOIN: 'true'
      MATRIX_ENCRYPTION: 'true'
      MATRIX_THREADS: 'true'
      MATRIX_PREFIX_DM: 'false'
      MATRIX_RICH_TEXT: 'true'
{% endif %}
