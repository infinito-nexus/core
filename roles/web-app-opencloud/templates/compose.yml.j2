{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}
  {% set service_name = 'opencloud' %}
  {{ service_name }}:
    {{ lookup('container_image', application_id, 'opencloud') }}
    {{ lookup('compose_only', 'container_name', OPENCLOUD_CONTAINER) }}
    user: "0:0"
    entrypoint:
      - /bin/sh
    command: ["-c", "opencloud init || true; opencloud server"]
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_ports', ['opencloud', 'http', DOCKER_BIND_HOST]) | indent(4) }}
    {{ lookup('container_volumes', application_id, 'opencloud') | indent(4) }}
    {{ lookup('container_networks') | indent(4) }}

{{ lookup('compose_volumes', application_id) }}
{{ lookup('compose_networks') }}
