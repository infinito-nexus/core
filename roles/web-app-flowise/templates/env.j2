{% include 'roles/sys-svc-container/templates/env.j2' %}

LITELLM_MASTER_KEY={{ FLOWISE_LITELLM_MASTER_KEY }}
LITELLM_CONFIG=/etc/litellm/config.yaml

PORT={{ FLOWISE_PORT_INTERNAL }}
FLOWISE_USERNAME={{ lookup('users', 'administrator').username }}
FLOWISE_PASSWORD={{ lookup('users', 'administrator').password | dotenv_quote }}
DATABASE_TYPE=postgres
DATABASE_HOST={{ lookup('database', application_id, 'host') }}
DATABASE_PORT={{ lookup('database', application_id, 'port') }}
DATABASE_NAME={{ lookup('database', application_id, 'name') }}
DATABASE_USER={{ lookup('database', application_id, 'username') }}
DATABASE_PASSWORD={{ lookup('database', application_id, 'password') | dotenv_quote }}
FLOWISE_FILE_STORAGE_PATH=/root/.flowise/storage
FLOWISE_SECRETKEY_OVERWRITE={{ lookup('config', application_id, 'credentials.secret_key') | dotenv_quote }}
JWT_AUTH_TOKEN_SECRET={{ lookup('config', application_id, 'credentials.jwt_auth_token_secret') | dotenv_quote }}
JWT_REFRESH_TOKEN_SECRET={{ lookup('config', application_id, 'credentials.jwt_refresh_token_secret') | dotenv_quote }}
EXPRESS_SESSION_SECRET={{ lookup('config', application_id, 'credentials.express_session_secret') | dotenv_quote }}
TOKEN_HASH_SECRET={{ lookup('config', application_id, 'credentials.token_hash_secret') | dotenv_quote }}

{% if lookup('engine', 'qdrant', application_id, 'enabled') %}
QDRANT_URL={{ FLOWISE_QDRANT_INTERNAL_URL }}
{% endif %}
OPENAI_API_BASE={{ FLOWISE_LITELLM_INTERNAL_URL }}/v1
OPENAI_API_KEY={{ FLOWISE_LITELLM_MASTER_KEY }}

{% set email = lookup('email', application_id) %}
{% if email.enabled | bool %}
SMTP_HOST={{ email.host }}
SMTP_PORT={{ email.port }}
SMTP_USER={{ email.username }}
SMTP_PASSWORD={{ email.password | dotenv_quote }}
SENDER_EMAIL={{ email['from'] }}
{% endif %}
