{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}
  {% set service_name = MATOMO_SERVICE %}
  {{ service_name }}:
    {{ lookup('compose_only', 'container_name', MATOMO_NAME) }}
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_image', application_id, 'matomo') }}
    {{ lookup('container_ports', ['matomo', 'http', DOCKER_BIND_HOST]) | indent(4) }}
    {{ lookup('container_volumes', application_id, MATOMO_SERVICE) | indent(4) }}
    healthcheck:
      test:
        - CMD-SHELL
        - |
          code="$$(curl -s -o /dev/null -w '%{http_code}' http://127.0.0.1/index.php || echo 000)"; [ "$$code" -ge 200 ] && [ "$$code" -lt 400 ]
      interval: 10s
      timeout: 5s
      retries: 12
      start_period: 180s
    {{ lookup('container_depends_on', application_id) | indent(4) }}
    {{ lookup('container_networks') | indent(4) }}

  {% set service_name = MATOMO_BOOTSTRAP_SERVICE %}
  {% set docker_restart_policy = 'no' %}
  {% set docker_compose_env = MATOMO_BOOTSTRAP_ENV_FILE %}
  {{ service_name }}:
    {% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {% if DEPLOYMENT_MODE == 'compose' %}
    profiles:
      - "{{ MATOMO_BOOTSTRAP_PROFILE }}"
    {% endif %}
    {{ lookup('compose_only', 'container_name', MATOMO_BOOTSTRAP_NAME) }}
    {{ lookup('container_image', application_id, 'bootstrap') }}
    {{ lookup('depends_on', {MATOMO_SERVICE: 'service_healthy'}) }}

{{ lookup('compose_volumes', application_id) }}
{{ lookup('compose_networks') }}
