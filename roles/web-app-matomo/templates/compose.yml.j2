{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}
  {{ MATOMO_SERVICE }}:
    {{ lookup('compose_only', 'container_name', MATOMO_NAME) }}
{% set container_port = 80 %}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    image: "{{ MATOMO_IMAGE }}:{{ MATOMO_VERSION }}"
    ports:
      - "{{ DOCKER_BIND_HOST }}:{{ lookup('config', application_id, 'services.matomo.ports.local.http') }}:{{ container_port }}"
    {{ lookup('container_volumes', application_id, MATOMO_SERVICE) | indent(4) }}
    healthcheck:
      test:
        - CMD-SHELL
        - |
          [ "$$(curl -s -o /dev/null -w '%{http_code}' http://127.0.0.1/index.php || echo 000)" = "200" ]
      interval: 10s
      timeout: 5s
      retries: 12
      start_period: 60s
{{ lookup('container_depends_on', application_id) }}
{% include 'roles/sys-svc-container/templates/networks.yml.j2' %}

  {{ MATOMO_BOOTSTRAP_SERVICE }}:
{% set docker_restart_policy = 'no' %}
{% set docker_compose_env = MATOMO_BOOTSTRAP_ENV_FILE %}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
{% set docker_compose_env = '' %}
{% set docker_restart_policy = DOCKER_RESTART_POLICY %}
{% if DEPLOYMENT_MODE != 'swarm' %}
    profiles:
      - "{{ MATOMO_BOOTSTRAP_PROFILE }}"
{% endif %}
    {{ lookup('compose_only', 'container_name', MATOMO_BOOTSTRAP_NAME) }}
    image: "{{ MATOMO_BOOTSTRAP_IMAGE }}:{{ MATOMO_BOOTSTRAP_VERSION }}"
    {{ lookup('depends_on', {MATOMO_SERVICE: 'service_healthy'}) }}

{{ lookup('compose_volumes', application_id) }}
{% include 'roles/sys-svc-compose/templates/networks.yml.j2' %}
