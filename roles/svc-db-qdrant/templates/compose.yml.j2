{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

  qdrant:
    {{ lookup('compose_only', 'container_name', QDRANT_CONTAINER) }}
    {{ lookup('container_image', application_id, 'qdrant') }}

{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
{% if QDRANT_EXPOSE_LOCAL %}
    {{ lookup('container_ports', ['qdrant', 'qdrant', DOCKER_BIND_HOST]) | indent(4) }}
{% endif %}
    {{ lookup('container_volumes', application_id, 'qdrant') | indent(4) }}
    {{ lookup('container_networks') | indent(4) }}
    healthcheck:
      test:
        - "CMD-SHELL"
        - "bash -c 'exec 3<>/dev/tcp/127.0.0.1/6333; printf \"GET /readyz HTTP/1.0\\r\\n\\r\\n\" >&3; grep -q \"200 OK\" <&3'"
      interval: 10s
      timeout: 5s
      retries: 18
      start_period: 60s

{{ lookup('compose_volumes', application_id) }}
{{ lookup('compose_networks') }}
