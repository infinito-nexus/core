{% include 'roles/sys-svc-compose/templates/base.yml.j2' %}

  seaweedfs:
{% set service_name = 'seaweedfs' %}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_image', application_id, 'seaweedfs') }}
    {{ lookup('compose_only', 'container_name', SEAWEEDFS_CONTAINER) }}
    command: {{ '/etc/seaweedfs/s3.json' | seaweedfs_command | to_json }}
    {{ lookup('container_ports', ['seaweedfs', 'http', DOCKER_BIND_HOST]) | indent(4) }}
    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
    {{ lookup('container_networks') | indent(4) }}

  proxy:
{% set service_name = 'proxy' %}
{% include 'roles/sys-svc-container/templates/base.yml.j2' %}
    {{ lookup('container_image', application_id, 'proxy') }}
    {{ lookup('compose_only', 'container_name', SEAWEEDFS_PROXY_CONTAINER) }}
    hostname: {{ SEAWEEDFS_PROXY_CONTAINER }}
    {{ lookup('container_volumes', application_id, service_name) | indent(4) }}
    {{ lookup('depends_on', {'seaweedfs': 'service_started'}) }}
    {{ lookup('container_networks', provider_self_alias=False) | indent(4) }}

{{ lookup('compose_volumes', application_id) }}
{{ lookup('compose_networks') }}
