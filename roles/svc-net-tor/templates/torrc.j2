# Managed by Infinito.Nexus (roles/svc-net-tor) — do not edit by hand.
RunAsDaemon 0
Log notice stdout
DataDirectory /var/lib/tor

SocksPort {{ lookup('tor_socks', '0.0.0.0') }}
SocksPolicy accept 127.0.0.0/8
SocksPolicy accept 10.0.0.0/8
SocksPolicy accept 172.16.0.0/12
SocksPolicy accept 192.168.0.0/16
SocksPolicy reject *
ControlPort 127.0.0.1:9051
CookieAuthentication 1

{% if not (TOR_USE_ENTRY_GUARDS | bool) %}
UseEntryGuards 0
{% endif %}

{% if TOR_EGRESS_ROUTER_ENABLED | bool %}
AutomapHostsOnResolve 1
AutomapHostsSuffixes .onion
VirtualAddrNetworkIPv4 {{ TOR_EGRESS_VIRTUAL_NET_IPV4 }}
TransPort 127.0.0.1:{{ TOR_TRANS_PORT }}
DNSPort 127.0.0.1:{{ TOR_DNS_PORT }}
{% endif %}
HiddenServiceDir /var/lib/tor/infinito/node/
HiddenServiceVersion 3
HiddenServicePort 80 {{ TOR_HS_BACKEND_HOST }}:80
{% for _p in TOR_ONION_EXTRA_PORTS %}
HiddenServicePort {{ _p.onion_port }} {{ TOR_HS_BACKEND_HOST }}:{{ _p.target.rsplit(':', 1) | last }}
{% endfor %}
